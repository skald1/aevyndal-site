---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteShell from "../components/home/SiteShell.astro";
import HeroSection from "../components/home/HeroSection.astro";
import StoryPromises from "../components/home/StoryPromises.astro";
import StartingLocationCards from "../components/home/StartingLocationCards.astro";
import IdentityCards from "../components/home/IdentityCards.astro";
import AgeExplorer from "../components/home/AgeExplorer.astro";
import FeaturedArticles from "../components/home/FeaturedArticles.astro";
import LivingWorldSection from "../components/home/LivingWorldSection.astro";
import CommunitySection from "../components/home/CommunitySection.astro";
import { getCollection } from "astro:content";
import { media } from "../data/media";
import "../styles/pages/home.scss";

const ages = (await getCollection("ages", ({ data }) => !data.draft)).sort(
  (a, b) => a.data.homepageOrder - b.data.homepageOrder || a.data.ordinal - b.data.ordinal,
);

const locations = (await getCollection(
  "locations",
  ({ data }) => !data.draft && data.homepageFeatured,
)).sort((a, b) => a.data.homepageOrder - b.data.homepageOrder);
---

<BaseLayout
  title="Ævyndal — Find Who You Could Be"
  description="Find a place, a people, and a story you could belong to in the living world of Ævyndal."
  showStickyNav={false}
  preloadImage={media.home.heroPoster}
>
  <SiteShell>
    <HeroSection />
    <StoryPromises />
    <StartingLocationCards locations={locations} />
    <IdentityCards />
    <AgeExplorer ages={ages} />
    <FeaturedArticles />
    <LivingWorldSection />
    <CommunitySection />
  </SiteShell>
</BaseLayout>

<script src="../scripts/home.ts"></script>
