{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "aevyndal",
  "compatibility_date": "2026-06-19",
  "pages_build_output_dir": "./dist",
  "r2_buckets": [
    {
      "binding": "MEDIA",
      "bucket_name": "aevyndal-media",
      "preview_bucket_name": "aevyndal-media-preview"
    }
  ]
}
