---
interface Props {
  href: string;
  label: string;
}

const { href, label } = Astro.props;
---

<a class="scroll-cue" href={href} aria-label={label}>
  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m6 9 6 6 6-6"></path></svg>
</a>

<style>
  .scroll-cue { position: absolute; z-index: 5; bottom: 1rem; left: 50%; width: 2.8rem; height: 2.8rem; display: grid; place-items: center; color: inherit; border: 1px solid var(--line); border-radius: 50%; transform: translateX(-50%); }
  .scroll-cue svg { width: 1.1rem; fill: none; stroke: currentColor; stroke-width: 1.5; }
</style>
