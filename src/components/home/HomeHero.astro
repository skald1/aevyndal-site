---
import WorldOverviewCard from "./WorldOverviewCard.astro";
---

<section class="home-hero" id="homeHero" aria-labelledby="home-title">
  <div class="mobile-header">
    <a class="mobile-header__brand" href="/">Ævyndal</a>
    <button class="mobile-header__menu" type="button" data-menu-toggle aria-expanded="false" aria-controls="mobile-menu">
      Menu
    </button>
  </div>
  <nav class="mobile-menu" id="mobile-menu" data-open="false" aria-label="Mobile navigation">
    <a href="/about">What is this?</a>
    <a href="/#starting-locations">Put me somewhere</a>
    <a href="/#identity-paths">Who could I be?</a>
    <a href="/community">Can I belong?</a>
  </nav>

  <nav class="hero-tabs" aria-label="Ways into Aevyndal">
    <a class="hero-tab" href="/about">What is this?</a>
    <a class="hero-tab" href="#starting-locations">Put me somewhere</a>
    <a class="hero-tab" href="#identity-paths">Who could I be?</a>
    <a class="hero-tab" href="#stories">What stories live here?</a>
  </nav>

  <div class="hero-grid">
    <div class="hero-copy">
      <p class="hero-wordmark">Ævyndal</p>
      <h1 id="home-title">Find a place that needs you.<br /><span>Become someone who belongs.</span></h1>
      <span class="hero-accent" aria-hidden="true"></span>
      <p class="hero-copy__body">
        Begin with a home, a responsibility, and someone worth showing up for.<br />
        The history can wait until it matters to your story.
      </p>
      <div class="action-row">
        <a class="age-cta" href="#starting-locations">
          <span>PUT ME SOMEWHERE</span>
          <span class="age-cta__arrow" aria-hidden="true">›</span>
        </a>
        <a class="button button--ghost" href="#identity-paths">WHO COULD I BE?</a>
      </div>
    </div>
    <WorldOverviewCard />
  </div>
</section>
