---
import { worldMetrics } from "../../data/home";

const metricIcons = ["⌂", "◇", "○", "✦"];
---

<aside class="world-card" aria-labelledby="world-card-title">
  <div class="world-card__inner">
    <p class="world-card__eyebrow">Your Way Into</p>
    <h2 id="world-card-title" class="world-card__title">
      Ævyndal <span aria-hidden="true">✦</span>
    </h2>
    <div class="world-card__divider" aria-hidden="true"></div>

    <dl class="world-card__stats">
      {worldMetrics.map((metric, index) => (
        <div class="world-card__row">
          <dt>
            <span class="world-card__icon" aria-hidden="true">{metricIcons[index]}</span>
            <span class="world-card__word">
              {metric.value}
            </span>
          </dt>
          <dd>{metric.label}</dd>
        </div>
      ))}
    </dl>

    <blockquote class="world-card__quote">
      <p>
        “You do not need to know the whole world.<br />
        Begin with the people<br />
        who would notice<br />
        if you did not come home.”
      </p>
    </blockquote>

    <div class="world-card__endmark" aria-hidden="true"></div>
  </div>
</aside>
