---
import SectionHeader from "./SectionHeader.astro";
---

<section class="home-section community" id="community" aria-labelledby="community-title">
  <div class="community__inner">
    <SectionHeader
      label="Can I belong?"
      title="There is room at the table."
      description="Watch a story unfold, help choose what opens next, or simply stay near the fire for a while."
    />
    <div class="community__paths">
      <a href="/community">
        <span>Gather</span>
        <strong>Meet the community</strong>
        <small>Discord, conversations, and shared work</small>
      </a>
      <a href="#living-world">
        <span>Witness</span>
        <strong>Watch the stories</strong>
        <small>Actual plays and records from the table</small>
      </a>
      <a href="#starting-locations">
        <span>Shape</span>
        <strong>Choose the next door</strong>
        <small>Polls and public decisions about what grows</small>
      </a>
    </div>
  </div>
</section>
