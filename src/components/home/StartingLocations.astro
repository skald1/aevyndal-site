---
import { startingLocations } from "../../data/home";
---

<section class="module starting-locations" id="starting-locations" aria-labelledby="starting-locations-title">
  <div class="module__header">
    <p class="eyebrow">Starting locations</p>
    <h3 id="starting-locations-title">Open the map through play.</h3>
  </div>
  <div class="location-list">
    {startingLocations.map((location) => (
      <article class="location-card">
        <div class="location-card__top">
          <h4>{location.name}</h4>
          <span>{location.status}</span>
        </div>
        <p><strong>What is it?</strong> {location.type}</p>
        <p><strong>Game here:</strong> {location.game}</p>
        <p><strong>Why start here?</strong> {location.why}</p>
      </article>
    ))}
  </div>
</section>
