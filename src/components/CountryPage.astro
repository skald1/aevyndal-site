---
import '../styles/country.css';
const { entry } = Astro.props;
const { Content } = await entry.render();
const fm = entry.data;

const isPatron = false;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={fm.seo_description} />
  <title>{fm.name} — Ævyndal Atlas</title>
</head>
<body>

  <nav class="nav">
    <div class="nav-logo">Ævyndal</div>
    <div class="nav-links">
      <a href="/atlas">Atlas</a>
      <a href="/about">About</a>
      <a href="/community">Community</a>
    </div>
  </nav>

  <div class="hero" style={`background-image: url('${fm.hero_image}')`}>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <div class="age-tag">{fm.age}</div>
      <h1 class="hero-name">{fm.name}</h1>
      {fm.pronunciation && <div class="hero-pronounce">{fm.pronunciation}</div>}
      <div class="hero-tagline">{fm.tagline}</div>
    </div>
    <div class="hero-rule"></div>
  </div>

  <div class="crumb">
    <span>Atlas › Erinnal › {fm.name}</span>
  </div>

  <div class="dossier">
    <div class="stat-panel">
      <div class="stat-header">At a glance</div>
      <div class="stat-row">
        <div class="stat-label">Government</div>
        <div class="stat-value">{fm.government}</div>
      </div>
      <div class="stat-row">
        <div class="stat-label">Capital</div>
        <div class="stat-value">{fm.capital}</div>
      </div>
      <div class="stat-row">
        <div class="stat-label">Region</div>
        <div class="stat-value">{fm.region}</div>
      </div>
      <div class="stat-row">
        <div class="stat-label">Climate</div>
        <div class="stat-value">{fm.climate}</div>
      </div>
      <div class="stat-row">
        <div class="stat-label">Primary faith</div>
        <div class="stat-value">{fm.faith}</div>
      </div>
      <div class="stat-row">
        <div class="stat-label">Dominant lineages</div>
        <ul class="lineage-list">
          {fm.lineages.map(l => <li class="lineage-item">{l}</li>)}
        </ul>
      </div>
      {isPatron ? (
        <>
          <div class="stat-row">
            <div class="stat-label">Current ruler</div>
            <div class="stat-value">{fm.ruler}</div>
          </div>
          <div class="stat-row">
            <div class="stat-label">Active conflicts</div>
            <div class="stat-value">{fm.conflicts}</div>
          </div>
        </>
      ) : (
        <>
          <div class="stat-row">
            <div class="stat-label">Current ruler</div>
            <div class="stat-missing">— available to Patreon supporters</div>
          </div>
          <div class="stat-row">
            <div class="stat-label">Active conflicts</div>
            <div class="stat-missing">— available to Patreon supporters</div>
          </div>
          <div class="patreon-note">
            <p class="patreon-text">The full dossier is available to Patreon supporters.</p>
            <a class="patreon-link" href="https://patreon.com/aevyndal">Support Ævyndal →</a>
          </div>
        </>
      )}
    </div>

    <div class="overview-panel">
      <div class="overview-header">Overview</div>
      <div class="overview-text">
        <Content />
      </div>
    </div>
  </div>

</body>
</html>