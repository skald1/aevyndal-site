---
import TopHeaderNav from "../components/nav/TopHeaderNav.astro";
import "../styles/global.css";

const { title = "Ævyndal", description = "", showStickyNav = true } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>
  <body>
    {showStickyNav && <TopHeaderNav />}
    <slot />
  </body>
</html>
