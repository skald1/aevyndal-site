---
import SiteNav from "../components/SiteNav.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  homepage?: boolean;
}

const { title, description, homepage = false } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#2a2440" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <link rel="canonical" href={canonical} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class:list={{ "is-homepage": homepage }}>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <SiteNav homepage={homepage} />
    <slot />
  </body>
</html>
