---
import HomeLayout from "../layouts/HomeLayout.astro";

const ages = [
  {
    ordinal: "First Age",
    name: "Age of Creation",
    genre: "Creation myth, fae fantasy, primordial wonder.",
    continents: "Pre-continental / world still forming.",
    scope: "No formal countries.",
    lineages: "Italti, early th'il precursors, primal spirits, divine-touched beings.",
    notableLineages: "Italti.",
    magic: "Elemental forces are raw, immediate, and mythic.",
    technology: "Pre-civilizational.",
    status: "Mythic foundation.",
    regions: "Felwiddel, early Elydris, primordial Vaunor.",
    support: "Lore foundation, creation myths, metaphysical reference.",
    hook: "Stories about first names, first bargains, first betrayals, and the shaping of reality.",
  },
  {
    ordinal: "Second Age",
    name: "Age of Italti",
    genre: "Sword-and-sandals mythic fantasy, empire, divine ruin.",
    continents: "Erinnal, Maj'ridal, Aris.",
    scope: "Early civilizations, sacred territories, city-states, proto-kingdoms.",
    lineages: "Italti, Children of the Italti, early mortal peoples.",
    notableLineages: "Korvad'an, Odoko, Maraki, Geraki, Sadrath.",
    magic: "High, dangerous, and poorly understood by mortals.",
    technology: "Bronze / early classical.",
    status: "Partially developed.",
    regions: "Italti ruins, early sacred sites, Aris.",
    support: "Lore foundation, ancient ruins, historical mysteries.",
    hook: "Mortal cultures rise beneath the shadow of beings too powerful to fully understand.",
  },
  {
    ordinal: "Third Age",
    name: "Age of Expansion",
    genre: "High fantasy, exploration, kingdoms, trade, cultural formation.",
    continents: "Erinnal, Maj'ridal, Aris.",
    scope: "Nations, roads, temples, schools, ports, and trade routes expand.",
    lineages: "Most modern kin-groups are present or emerging.",
    notableLineages: "Major mortal lineages and regional cultures become recognizable.",
    magic: "Known, studied, feared, and institutionalized in places.",
    technology: "Medieval / high fantasy.",
    status: "Broadly outlined.",
    regions: "Wyth Tyr'il, Erinnal, Maj'ridal.",
    support: "Atlas material, historical reference, campaign foundations.",
    hook: "A world becoming legible, dangerous, ambitious, and connected.",
  },
  {
    ordinal: "Fourth Age",
    name: "Age of Shadowed Crowns",
    genre: "Dark medieval fantasy, folklore horror, feudal pressure.",
    continents: "Erinnal, Maj'ridal, Aris.",
    scope: "Broad national and regional structure; feudal states, isolated settlements, contested territories.",
    lineages: "Adri'il, Fayd'il, Lithar'il, Myrad'il, Ryal'il, Slindar'il, Theran'il, Vaud'il, Human, Umbran, Vivashan, Karuun, Guelt, Gol, Gnome, Igyrlin, Tirfolk, Korvad'an, Odoko, Maraki, Geraki, Sadrath, Sheydra, Rech, Thiraf, Värul, Kobold, Goblin, T'nao, Gulvani.",
    notableLineages: "Sheydra and several post-Italti mortal peoples are fully active in play.",
    magic: "Rare, costly, feared, and culturally distorted.",
    technology: "Medieval / dark fantasy.",
    status: "Highly developed.",
    regions: "Mütvia, Krethavar, Wyth Tyr'il, Aris.",
    support: "Pathfinder 2e Remaster material, adventures, maps, actual-play support, regional lore.",
    hook: "Villages survive between noble power, superstition, old magic, hunger, and things in the woods.",
    open: true,
  },
  {
    ordinal: "Fifth Age",
    name: "Age of Ruin",
    genre: "Post-apocalyptic fantasy, survival, rewilding, broken kingdoms.",
    continents: "Erinnal, Maj'ridal, Aris.",
    scope: "Collapsed states, isolated settlements, ruin-zones, survival territories.",
    lineages: "All major mortal lineages plus created beings such as Wrought and Fifth Age Automatons.",
    notableLineages: "Wrought, Fifth Age Automatons.",
    magic: "Rare, dangerous, half-remembered, and often misused.",
    technology: "Post-collapse / scavenged / early steampunk remnants.",
    status: "Active development.",
    regions: "Mütvia aftermath regions, ruin settlements, rewilded territories.",
    support: "Campaign concepts, survival play, creature design, regional expansion.",
    hook: "The old world failed. The new one is feral, hungry, and full of things people were never meant to wake.",
  },
  {
    ordinal: "Sixth Age",
    name: "Age of Smoke and Secrets",
    genre: "Industrial fantasy, gothic science, occult conspiracy.",
    continents: "Erinnal, Maj'ridal, Aris, and expanding global networks.",
    scope: "Industrial nations, colonial pressure, rail corridors, factory cities, academic centers.",
    lineages: "Established peoples adapting to industry, class pressure, and hidden experimentation.",
    notableLineages: "Experimental created beings, altered bloodlines, early artificial life.",
    magic: "Studied, restricted, commodified, and hidden behind institutions.",
    technology: "Industrial / gaslight / early modern science.",
    status: "Outlined / future development.",
    regions: "Industrial cities, secret societies, universities, occult laboratories.",
    support: "Conceptual framework, future campaign support.",
    hook: "Science, magic, religion, and industry stop pretending they are separate forces.",
  },
  {
    ordinal: "Seventh Age",
    name: "Syndicate Age",
    genre: "Dystopian dark science fiction, corporate rule, grimdark futurism.",
    continents: "Global and intersystem.",
    scope: "Dominions, megastructures, surveillance states, corporate territories.",
    lineages: "Modern peoples, androids, altered humans, corporate-designed bodies.",
    notableLineages: "Androids and engineered peoples.",
    magic: "Engineered, exploited, suppressed, or converted into systems of control.",
    technology: "Hypertech / cyberpunk / dark science fiction.",
    status: "Conceptual but structurally important.",
    regions: "Dominions, corporate arcologies, surveillance states, off-world infrastructure.",
    support: "Dominion lore, future campaign structure, dystopian reference.",
    hook: "The world survives, but ownership replaces stewardship.",
  },
  {
    ordinal: "Eighth Age",
    name: "Brightpunk Age",
    genre: "Brightpunk, post-dystopian recovery, science-magic-faith integration.",
    continents: "Global and intersystem.",
    scope: "Reclaimed cities, restored biomes, new alliances, post-Dominion futures.",
    lineages: "Broadest lineage access; cultural, technological, and metaphysical synthesis.",
    notableLineages: "Future-facing created and restored peoples as needed.",
    magic: "Integrated into civic life, ecological restoration, science, medicine, and spiritual practice.",
    technology: "Brightpunk / ecological futurism / advanced synthesis.",
    status: "Developed as future-facing thesis.",
    regions: "Reclaimed cities, restored wilds, intersystem routes, post-Syndicate communities.",
    support: "Brightpunk preview material, actual-play future, worldbuilding thesis.",
    hook: "The question is no longer whether civilization can survive. It is what kind of civilization deserves to.",
  },
];

const mutviaBeats = [
  {
    label: "The Land",
    heading: "The ground remembers everything.",
    body: "Mütvia's soil has held more death than any earth was ever meant to contain. It doesn't forget. It doesn't release. The dead don't always stay where you put them — and whether that's your fault depends entirely on whether you knew the rite.",
    tag: "Cosmology",
  },
  {
    label: "The Government",
    heading: "Anyone can be a prince. Few last.",
    body: "No capital. No throne. No central authority. Authority belongs to whoever stands on land and keeps it — against rivals, against creatures, against the things that walk at night. The title is Ströikas. It's earned by endurance, not bloodline.",
    tag: "Politics",
  },
  {
    label: "The History",
    heading: "The war that shattered everything.",
    body: "In 659 IC, two noble houses fought a war neither should have started. When it ended, both were gone. The peasants kept the castles. The blood soaked into the ground. Some of it is still rising.",
    tag: "History",
  },
  {
    label: "The Drósti",
    heading: "Five families. No fixed ground. No equal.",
    body: "The drósti walk roads where law, memory, and spirit-work fail everyone else. Wolf-blooded pilgrims. Fallen intelligence networks. Demonic bloodlines who hold the forest. Sky-watchers with gifts they refuse to name.",
    tag: "Factions",
  },
  {
    label: "The Villain",
    heading: "He built his name around killing what he became.",
    body: "Ra'ath Wolvesbane founded the Argentati — the Silvered Ones — to hunt lycanthropes. They skin their kills and wear the hides. Their leader is a lycanthrope. He hasn't told them. He hunts harder instead.",
    tag: "Threat",
  },
  {
    label: "The Rules",
    heading: "Superstition is survival. Learn the difference.",
    body: "A single knock at the door, followed by your name: do not answer. The Vodniki will challenge you to a game — know the rules before they invite you. Some houses drain the living. The first symptom is a pleasant, deep tiredness.",
    tag: "Lore",
  },
];
---

<HomeLayout
  title="Ævyndal — An Original Dark Fantasy Universe"
  description="One world. Eight epochs. Dark medieval fantasy to cosmic science fiction, all connected. The Fourth Age is open now. Start in Mütvia."
>

  <!-- ═══════════════════════════════════════
       HERO
  ═══════════════════════════════════════ -->
  <section class="hero" aria-labelledby="hero-heading">
    <!-- GRAPHIC PLACEHOLDER: Full-bleed hero image
         Specs: 1920×1080px minimum, dark atmospheric fantasy landscape
         Mood: void black with distant burning horizon, negative space left side
         Format: WebP, served from evindale.com/wp-content/uploads/
         Current bg handled by BackgroundLayer component (radial blood-orange glow on void) -->
    <div class="hero-inner">
      <div class="hero-logo-wrap">
        <img
          src="https://evindale.com/wp-content/uploads/2026/06/AevyndalNewLogo.png"
          alt="Ævyndal"
          class="hero-logo"
          width="160"
          height="160"
        />
      </div>
      <h1 class="hero-title" id="hero-heading">
        One world.<br/>
        <em>Eight epochs.</em><br/>
        Every story persists.
      </h1>
      <p class="hero-sub">
        Dark medieval horror. Cosmic science fiction. Industrial conspiracy. Post-dystopian recovery.<br/>
        All the same world. All the same history. The Fourth Age is open.
      </p>
      <div class="hero-cta">
        <a href="/mutvia" class="btn-primary">Enter Mütvia</a>
        <a href="#ages" class="btn-ghost">See all eight ages</a>
      </div>
    </div>
    <div class="hero-scroll" aria-hidden="true">
      <div class="hero-scroll-line"></div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       PROPOSITION STRIP
  ═══════════════════════════════════════ -->
  <section class="prop-strip" aria-label="What Ævyndal offers">
    <div class="prop-strip-inner">
      <div class="prop">
        <span class="prop-icon">◈</span>
        <strong>No elves. No dwarves.</strong>
        <span>30+ original peoples across seven lineage families.</span>
      </div>
      <div class="prop-divider" aria-hidden="true"></div>
      <div class="prop">
        <span class="prop-icon">◈</span>
        <strong>No lore prerequisite.</strong>
        <span>Run tonight. The world fills in as you play.</span>
      </div>
      <div class="prop-divider" aria-hidden="true"></div>
      <div class="prop">
        <span class="prop-icon">◈</span>
        <strong>Nothing dies with a campaign.</strong>
        <span>Your characters persist. The world remembers.</span>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       AGES
  ═══════════════════════════════════════ -->
  <section class="section" id="ages" aria-labelledby="ages-heading">
    <div class="section-inner">
      <header class="section-head">
        <h2 class="section-title" id="ages-heading">The Eight Ages</h2>
        <div class="section-rule" aria-hidden="true"></div>
      </header>
      <p class="section-sub">One world. Eight epochs. Each carries its own genre, its own relationship to magic, its own version of what survival costs. The Fourth Age is open now.</p>
      <div class="ages-grid" role="list">
        {ages.map((age, index) => (
          <button
            class:list={["age-card", age.open && "open-now"]}
            type="button"
            aria-expanded="false"
            aria-controls="age-modal"
            data-age-index={index}
            role="listitem"
          >
            {age.open && <span class="age-open-mark">Open Now</span>}
            <span class="age-num">{age.ordinal}</span>
            <span class="age-name">{age.name}</span>
            <span class="age-genre">{age.genre}</span>
            <span class="age-action" aria-hidden="true">Details</span>
          </button>
        ))}
      </div>

      <!-- AGE MODAL -->
      <div class="age-modal-shell" id="age-modal-shell" hidden>
        <div class="age-modal-overlay" data-age-modal-close></div>
        <section
          class="age-modal"
          id="age-modal"
          role="dialog"
          aria-modal="true"
          aria-labelledby="age-modal-title"
          tabindex="-1"
        >
          <button class="age-modal-close" type="button" aria-label="Close age details" data-age-modal-close>✕</button>
          <div class="age-panel-head">
            <div>
              <div class="age-panel-label">Age Name</div>
              <h3 id="age-modal-title"></h3>
            </div>
            <div class="age-status" id="age-modal-status"></div>
          </div>
          <dl class="age-chips" aria-label="Age quick facts">
            <div><dt>Continents</dt><dd id="age-modal-continents"></dd></div>
            <div><dt>Scope</dt><dd id="age-modal-scope"></dd></div>
            <div><dt>Magic</dt><dd id="age-modal-magic"></dd></div>
            <div><dt>Technology</dt><dd id="age-modal-technology"></dd></div>
          </dl>
          <div class="age-fields">
            <div class="age-field"><span>Genre / Play Mode</span><p id="age-modal-genre"></p></div>
            <div class="age-field"><span>New or Notable Lineages</span><p id="age-modal-notable-lineages"></p></div>
            <div class="age-field"><span>Featured Regions</span><p id="age-modal-regions"></p></div>
            <div class="age-field"><span>Current Play Support</span><p id="age-modal-support"></p></div>
            <div class="age-field age-field--wide"><span>Play Hook</span><p id="age-modal-hook"></p></div>
          </div>
          <div class="age-lineages">
            <span>Lineages Available</span>
            <p id="age-modal-lineages"></p>
          </div>
        </section>
      </div>
      <script type="application/json" id="age-data" set:html={JSON.stringify(ages)}></script>
    </div>
  </section>

  <script>
    const ageDataNode = document.getElementById("age-data");
    const ageControls = Array.from(document.querySelectorAll("[data-age-index]"));
    const modalShell = document.getElementById("age-modal-shell");
    const modal = document.getElementById("age-modal");
    const closeControls = Array.from(document.querySelectorAll("[data-age-modal-close]"));
    const ages = ageDataNode ? JSON.parse(ageDataNode.textContent || "[]") : [];
    let activeTrigger = null;

    const fields = {
      title: document.getElementById("age-modal-title"),
      status: document.getElementById("age-modal-status"),
      continents: document.getElementById("age-modal-continents"),
      scope: document.getElementById("age-modal-scope"),
      magic: document.getElementById("age-modal-magic"),
      technology: document.getElementById("age-modal-technology"),
      genre: document.getElementById("age-modal-genre"),
      notableLineages: document.getElementById("age-modal-notable-lineages"),
      regions: document.getElementById("age-modal-regions"),
      support: document.getElementById("age-modal-support"),
      hook: document.getElementById("age-modal-hook"),
      lineages: document.getElementById("age-modal-lineages"),
    };

    function setField(key, value) {
      if (fields[key]) fields[key].textContent = value || "";
    }

    function getFocusable() {
      if (!modal) return [];
      return Array.from(
        modal.querySelectorAll('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])')
      ).filter(el => !el.hasAttribute("disabled") && !el.getAttribute("aria-hidden"));
    }

    function closeModal() {
      if (!modalShell || modalShell.hidden) return;
      modalShell.hidden = true;
      document.body.classList.remove("age-modal-open");
      ageControls.forEach(c => c.setAttribute("aria-expanded", "false"));
      if (activeTrigger instanceof HTMLElement) activeTrigger.focus();
      activeTrigger = null;
    }

    function openModal(index, trigger) {
      const age = ages[index];
      if (!age || !modalShell || !modal) return;
      activeTrigger = trigger;
      setField("title", age.name);
      setField("status", age.status);
      setField("continents", age.continents);
      setField("scope", age.scope);
      setField("magic", age.magic);
      setField("technology", age.technology);
      setField("genre", age.genre);
      setField("notableLineages", age.notableLineages);
      setField("regions", age.regions);
      setField("support", age.support);
      setField("hook", age.hook);
      setField("lineages", age.lineages);
      ageControls.forEach(c => c.setAttribute("aria-expanded", "false"));
      trigger.setAttribute("aria-expanded", "true");
      modalShell.hidden = false;
      document.body.classList.add("age-modal-open");
      const focusables = getFocusable();
      (focusables[0] || modal).focus();
    }

    ageControls.forEach(c => {
      c.addEventListener("click", () => openModal(Number(c.dataset.ageIndex), c));
    });
    closeControls.forEach(c => c.addEventListener("click", closeModal));
    document.addEventListener("keydown", e => {
      if (!modalShell || modalShell.hidden) return;
      if (e.key === "Escape") { e.preventDefault(); closeModal(); return; }
      if (e.key !== "Tab") return;
      const focusables = getFocusable();
      if (!focusables.length) { e.preventDefault(); modal?.focus(); return; }
      const first = focusables[0], last = focusables[focusables.length - 1];
      if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
      else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
    });
  </script>

  <!-- ═══════════════════════════════════════
       MÜTVIA PREVIEW
  ═══════════════════════════════════════ -->
  <section class="mutvia-preview" id="mutvia" aria-labelledby="mutvia-heading">
    <div class="mutvia-preview-inner">

      <div class="mutvia-intro">
        <!-- GRAPHIC PLACEHOLDER: Mütvia logo
             Use: https://evindale.com/wp-content/uploads/2024/05/Mutvia-Logo-2024.webp
             Display at ~280px wide, centered above headline -->
        <img
          src="https://evindale.com/wp-content/uploads/2024/05/Mutvia-Logo-2024.webp"
          alt="Mütvia"
          class="mutvia-logo"
          width="280"
          height="auto"
          loading="lazy"
        />
        <div class="mutvia-label">Fourth Age · Northern Erinnal · Open Now</div>
        <h2 class="mutvia-heading" id="mutvia-heading">The Land of 1,000 Princes</h2>
        <p class="mutvia-desc">
          A country with no capital, no throne, and no central authority.
          Whatever you hold, you hold by your own hand. Whatever you lose, you lost it.
          The dead don't stay down here. The Land is watching. And the rites that keep it satisfied
          are older than anyone alive still fully understands.
        </p>
        <blockquote class="mutvia-verse">
          <em>The wind quiets before it kills.</em>
          <em>The trees lean when no one's looking.</em>
          <em>This is not superstition.</em>
          <em>This is how you survive.</em>
        </blockquote>
      </div>

      <!-- GRAPHIC PLACEHOLDER: Mütvia map or atmospheric landscape
           Specs: 1200×600px, dark-toned map or gothic landscape
           Position: full-width strip between intro and beat cards
           Format: WebP, loading="lazy"
           Replace src below with actual image URL -->
      <div class="mutvia-map-strip" aria-hidden="true">
        <div class="mutvia-map-placeholder">
          <!-- PLACEHOLDER: Replace with <img src="..." alt="Map of Mütvia" ...> -->
          <span class="map-placeholder-label">Map of Mütvia · Graphic here · 1200×500px recommended</span>
        </div>
      </div>

      <div class="mutvia-beats" role="list" aria-label="Mütvia preview">
        {mutviaBeats.map((beat) => (
          <article class="beat-card" role="listitem">
            <div class="beat-tag">{beat.tag}</div>
            <div class="beat-label">{beat.label}</div>
            <h3 class="beat-heading">{beat.heading}</h3>
            <p class="beat-body">{beat.body}</p>
          </article>
        ))}
      </div>

      <div class="mutvia-cta">
        <a href="/mutvia" class="btn-primary btn-large">Read the Full Atlas Entry</a>
        <p class="mutvia-cta-note">Complete lore, history, factions, threats, and tone of play.</p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       WORLDS
  ═══════════════════════════════════════ -->
  <section class="section section--worlds" id="worlds" aria-labelledby="worlds-heading">
    <div class="section-inner">
      <header class="section-head">
        <h2 class="section-title" id="worlds-heading">The Worlds</h2>
        <div class="section-rule" aria-hidden="true"></div>
      </header>
      <p class="section-sub">Sythlia's creation spans more than one world. The ages run through all of it.</p>
      <div class="worlds-grid">
        <div class="world-card">
          <div class="world-card-eye">Primary World · Active</div>
          <div class="world-card-name">Elydris</div>
          <div class="world-card-desc">The planet. Three continents shaped and reshaped by tectonic drift across the ages. Local star: Aryos. All current content originates here.</div>
        </div>
        <div class="world-card locked">
          <div class="world-card-eye">Secondary World · Locked</div>
          <div class="world-card-name">Felwiddel</div>
          <div class="world-card-desc">Origin world of the Dranorvauri. Fey concentration is higher here than anywhere else in Sythlia's creation. Not yet available.</div>
        </div>
      </div>
      <div class="sub-head">
        <span class="sub-head-title">Continents of Elydris</span>
        <div class="section-rule" aria-hidden="true"></div>
      </div>
      <div class="continents-grid">
        <div class="continent-card">
          <div class="continent-card-label">Primary Continent · Active</div>
          <div class="continent-card-name">Erinnal</div>
          <div class="continent-card-meta">43 countries · The home of adventure and the birthplace of the setting</div>
        </div>
        <div class="continent-card locked">
          <div class="continent-card-label">Second Continent · Locked</div>
          <div class="continent-card-name">Majri'dal</div>
          <div class="continent-card-meta">23 countries · Named, real, not yet available</div>
        </div>
        <div class="continent-card reserved">
          <div class="continent-card-label">Third Continent · Reserved</div>
          <div class="continent-card-name">Aris</div>
          <div class="continent-card-meta">The long destination · Available when the world is ready for it</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       LINEAGES
  ═══════════════════════════════════════ -->
  <section class="section" id="lineages" aria-labelledby="lineages-heading">
    <div class="section-inner">
      <header class="section-head">
        <h2 class="section-title" id="lineages-heading">30+ Original Peoples</h2>
        <div class="section-rule" aria-hidden="true"></div>
      </header>
      <p class="section-sub">No elves. No dwarves. No borrowed mythology. Original peoples across seven lineage families, each with their own origins, their own history, their own relationship to the eight elements. The roster grows with the world.</p>
      <div class="lineage-grid">
        <div class="family-card">
          <div class="family-name">Th'il</div>
          <div class="family-peoples">Adri'il · Fayd'il · Lithar'il · Myrad'il · Ryal'il · Slindar'il · Theran'il · Vaud'il</div>
          <span class="family-tag">8 Peoples</span>
        </div>
        <div class="family-card">
          <div class="family-name">Dranorvauri</div>
          <div class="family-peoples">Gnome · Gol · Guelt · Igyrlin · Karuun · Tirfolk</div>
          <span class="family-tag">6 Peoples</span>
        </div>
        <div class="family-card">
          <div class="family-name">Children of the Italti</div>
          <div class="family-peoples">Geraki · Korva'dan · Maraki · Odoko · Quirrin · Sadrath</div>
          <span class="family-tag">6 Peoples · Korva'dan available</span>
        </div>
        <div class="family-card">
          <div class="family-name">Klane</div>
          <div class="family-peoples">Human · Umbran · Vivashan</div>
          <span class="family-tag">3 Peoples</span>
        </div>
        <div class="family-card">
          <div class="family-name">Evolved</div>
          <div class="family-peoples">Gulvani · Thiraf · Värul</div>
          <span class="family-tag">3 Peoples</span>
        </div>
        <div class="family-card">
          <div class="family-name">Children of the Dreg'n</div>
          <div class="family-peoples">Goblin · Kobold · Kotera · T'nao</div>
          <span class="family-tag">4 Peoples</span>
        </div>
        <div class="family-card">
          <div class="family-name">Wrought</div>
          <div class="family-peoples">Rech · Sheydra · Fifth Age Automaton</div>
          <span class="family-tag">3 Peoples</span>
