const world = document.querySelector('.world');
const roleField = document.getElementById('roleField');
const phraseField = document.getElementById('phraseField');
const headline = document.getElementById('heroTitle');
const ageIndex = document.getElementById('ageIndex');
const ageName = document.getElementById('ageName');
const agePrompt = document.getElementById('agePrompt');
const pathTitle = document.getElementById('pathTitle');
const pathQuote = document.getElementById('pathQuote');
const pathMeta = document.getElementById('pathMeta');
const buttons = [...document.querySelectorAll('.age-btn')];
const toast = document.getElementById('toast');
let currentAge = 4;
let cycle;
let phraseCycle;

const ordinals = [
  null,
  ['1','st'],
  ['2','nd'],
  ['3','rd'],
  ['4','th'],
  ['5','th'],
  ['6','th'],
  ['7','th'],
  ['8','th']
];
function setAgeHeading(age){
  const [number, suffix] = ordinals[age];
  ageName.innerHTML = `<span class="age-line">${number}<sup>${suffix}</sup> Age:</span>${ages[age].name}`;
}
const positions = [
  [19,16,-1,.82],[40,10,1,.50],[63,13,0,.70],[87,16,1,.45],[24,31,-1,.78],[82,32,0,.78],[91,48,1,.65],[19,56,0,.75],[36,61,-1,.58],[74,59,1,.48],[24,68,0,.72],[56,72,1,.42],[80,76,-1,.52],[40,82,0,.64]
];
const phrasePositions = [
  [28,24,-8,12,-4],[72,25,7,-10,6],[39,48,-5,8,4],[66,54,5,-8,-3],[31,70,-3,12,-5],[74,73,4,-10,4]
];

function buildRoles(age, immediate=false){
  const words = ages[age].roles;
  const old = [...roleField.children];
  old.forEach(el=>el.classList.remove('visible'));
  const change = ()=>{
    roleField.innerHTML='';
    words.forEach((word,i)=>{
      const p=positions[i%positions.length];
      const el=document.createElement('span');
      el.className='role';el.textContent=word;
      el.style.setProperty('--x',p[0]+'%');el.style.setProperty('--y',p[1]+'%');
      el.style.setProperty('--r',p[2]+'deg');el.style.setProperty('--o',p[3]);
      el.style.setProperty('--dx',((i%3)-1)*6+'px');el.style.setProperty('--dy',((i%4)-1.5)*4+'px');
      roleField.appendChild(el);
      requestAnimationFrame(()=>setTimeout(()=>el.classList.add('visible'), immediate?0:60+i*42));
    });
  };
  if(immediate) change(); else setTimeout(change,520);
}

function buildPhrases(age, immediate=false){
  const phrases = ages[age].phrases;
  [...phraseField.children].forEach(el=>el.classList.remove('visible'));
  const change = ()=>{
    phraseField.innerHTML='';
    const used = [...phrases].sort(()=>Math.random()-.5);
    phrasePositions.forEach((p,i)=>{
      const el=document.createElement('span');
      el.className='phrase';
      el.dataset.ghost = i > 3 ? '1' : '0';
      el.textContent = used[i % used.length];
      el.style.setProperty('--px',p[0]+'%');
      el.style.setProperty('--py',p[1]+'%');
      el.style.setProperty('--pr',p[2]+'deg');
      el.style.setProperty('--pdx',p[3]+'px');
      el.style.setProperty('--pdy',p[4]+'px');
      phraseField.appendChild(el);
      requestAnimationFrame(()=>setTimeout(()=>el.classList.add('visible'), immediate?0:90+i*55));
    });
  };
  if(immediate) change(); else setTimeout(change,260);
}

function startPhraseCycle(){
  clearInterval(phraseCycle);
  phraseCycle = setInterval(()=>buildPhrases(currentAge), 3200);
}

function setAge(age,userInitiated=false){
  if(age===currentAge && userInitiated) return;
  currentAge=age;
  headline.classList.add('age-shift');
  buildRoles(age);
  buildPhrases(age);
  setTimeout(()=>{
    world.dataset.age=String(age);
    ageIndex.textContent=String(age).padStart(2,'0')+' / 08';
    setAgeHeading(age);
    agePrompt.textContent=ages[age].prompt;
    pathTitle.textContent=ages[age].path[0];
    pathQuote.textContent=ages[age].path[1];
    pathMeta.textContent=ages[age].path[2];
    buttons.forEach(b=>b.classList.toggle('active',Number(b.dataset.age)===age));
    headline.classList.remove('age-shift');
  },650);
  if(userInitiated) restartCycle();
}

function nextAge(){setAge(currentAge===8?1:currentAge+1)}
function restartCycle(){clearInterval(cycle);cycle=setInterval(nextAge,9000);startPhraseCycle()}
buttons.forEach(b=>b.addEventListener('click',()=>setAge(Number(b.dataset.age),true)));

buildRoles(4,true);
buildPhrases(4,true);
setAgeHeading(4);
restartCycle();
startPhraseCycle();

document.querySelectorAll('.path').forEach(btn=>btn.addEventListener('click',()=>showToast(btn.textContent+' — route preview opened')));
document.querySelectorAll('[data-nav]').forEach(btn=>btn.addEventListener('click',()=>{
  const target=btn.dataset.nav;
  if(target==='search') document.getElementById('archiveSearch').focus();
  else showToast(target+' index opened');
}));

document.getElementById('searchForm').addEventListener('submit',e=>{
  e.preventDefault();
  const q=document.getElementById('archiveSearch').value.trim();
  showToast(q?`Searching the archive for “${q}”`:'Enter a name, place, role, or age');
});

function showToast(msg){
  toast.textContent=msg;
  toast.classList.add('show');
  clearTimeout(showToast.t);
  showToast.t=setTimeout(()=>toast.classList.remove('show'),2200)
}

let raf;
window.addEventListener('pointermove',e=>{
  if(matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  cancelAnimationFrame(raf);
  raf=requestAnimationFrame(()=>{
    const nx=(e.clientX/innerWidth-.5), ny=(e.clientY/innerHeight-.5);
    [...roleField.children].forEach((el,i)=>{
      const depth=(i%5+1)*.7;
      el.style.marginLeft=(nx*depth*5)+'px';
      el.style.marginTop=(ny*depth*4)+'px';
    });
    [...phraseField.children].forEach((el,i)=>{
      const depth=(i%4+1)*.55;
      el.style.marginLeft=(nx*depth*8)+'px';
      el.style.marginTop=(ny*depth*6)+'px';
    });
  });
});
</script>
</body>
</html>
