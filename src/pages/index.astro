<style>
  :root {
    --void:         #09080A;
    --ink:          #1A1614;
    --haze:         #2E2926;
    --fog:          #3A3530;
    --ash:          #5C5650;
    --bone-dim:     #8A837A;
    --bone:         #D0C9BC;
    --threat:       #8B3218;
    --glow:         #C4501E;
    --font-display: 'Crimson Text', Georgia, serif;
    --font-body:    'Lora', Georgia, serif;
  }

  /* ━━━━━━━━━━━━━━━━━━━━━━━━
     HERO
  ━━━━━━━━━━━━━━━━━━━━━━━━ */
  .hero {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-end;
    padding: 0 clamp(1.5rem, 5vw, 6rem) clamp(5rem, 10vh, 9rem);
    position: relative;
    overflow: hidden;
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 40vh;
    background: linear-gradient(to top, var(--void) 0%, transparent 100%);
    pointer-events: none;
    z-index: 1;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 760px;
  }

  .hero-logo-wrap {
    margin-bottom: 2.5rem;
    opacity: 0;
    animation: rise 0.9s ease forwards 0.2s;
  }

  .hero-logo {
    width: clamp(100px, 12vw, 160px);
    height: auto;
    filter: drop-shadow(0 0 32px rgba(196,80,30,0.3));
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6.5rem);
    font-weight: 400;
    line-height: 1.0;
    color: var(--bone);
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: rise 1s ease forwards 0.4s;
  }

  .hero-title em {
    font-style: italic;
    color: var(--glow);
  }

  .hero-sub {
    font-family: var(--font-display);
    font-size: clamp(0.95rem, 1.8vw, 1.2rem);
    font-style: italic;
    color: var(--ash);
    max-width: 560px;
    line-height: 1.7;
    margin-bottom: 2.5rem;
    opacity: 0;
    animation: rise 1s ease forwards 0.6s;
  }

  .hero-cta {
    display: flex;
    gap: 2rem;
    align-items: center;
    flex-wrap: wrap;
    opacity: 0;
    animation: rise 1s ease forwards 0.8s;
  }

  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    right: clamp(1.5rem, 5vw, 6rem);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    opacity: 0;
    animation: fadeIn 1.5s ease forwards 1.5s;
  }

  .hero-scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, var(--glow), transparent);
    animation: scrollPulse 2s ease infinite;
  }

  @keyframes rise {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.8); transform-origin: top; }
    50%       { opacity: 1;   transform: scaleY(1);   transform-origin: top; }
  }

  /* ━━━━━━━━━━━━━━━━━━━━━━━━
     BUTTONS
  ━━━━━━━━━━━━━━━━━━━━━━━━ */
  .btn-primary {
    display: inline-block;
    padding: 0.8rem 2rem;
    background: var(--threat);
    color: var(--bone);
    font-family: var(--font-body);
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid var(--glow);
    transition: background 0.25s, box-shadow 0.25s;
  }

  .btn-primary:hover {
    background: var(--glow);
    box-shadow: 0 0 24px rgba(196,80,30,0.3);
  }

  .btn-large {
    padding: 1rem 2.5rem;
    font-size: 0.78rem;
  }

  .btn-ghost {
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ash);
    text-decoration: none;
    border-bottom: 1px solid var(--fog);
    padding-bottom: 0.1rem;
    transition: color 0.25s, border-color 0.25s;
  }

  .btn-ghost:hover { color: var(--bone); border-color: var(--ash); }

  /* ━━━━━━━━━━━━━━━━━━━━━━━━
     PROPOSITION STRIP
  ━━━━━━━━━━━━━━━━━━━━━━━━ */
  .prop-strip {
    background: var(--ink);
    border-top: 1px solid var(--fog);
    border-bottom: 1px solid var(--fog);
  }

  .prop-strip-inner {
    max-width: 1060px;
    margin: 0 auto;
    padding: 2rem clamp(1.5rem, 5vw, 3rem);
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    align-items: center;
    gap: 0;
  }

  .prop {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 1.25rem 1.5rem;
  }

  .prop-icon {
    font-size: 0.7rem;
    color: var(--glow);
    margin-bottom: 0.2rem;
  }

  .prop strong {
    font-family: var(--font-display);
    font-size: 0.95rem;
    color: var(--bone);
    font-weight: 600;
  }

  .prop span {
    font-size: 0.78rem;
    color: var(--ash);
    font-style: italic;
    line-height: 1.5;
  }

  .prop-divider {
    width: 1px;
    height: 3rem;
    background: var(--fog);
    flex-shrink: 0;
  }

  /* ━━━━━━━━━━━━━━━━━━━━━━━━
     SECTIONS
  ━━━━━━━━━━━━━━━━━━━━━━━━ */
  .section {
    padding: 5rem clamp(1.5rem, 5vw, 3rem);
  }

  .section-inner { max-width: 1060px; margin: 0 auto; }

  .section-head {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 600;
    color: var(--bone);
    line-height: 1;
    white-space: nowrap;
  }

  .section-rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--fog), transparent);
  }

  .section-sub {
    font-size: 0.84rem;
    color: var(--ash);
    font-style: italic;
    max-width: 560px;
    margin-bottom: 2.5rem;
    line-height: 1.65;
  }

  /* ━━━━━━━━━━━━━━━━━━━━━━━━
     AGES GRID
  ━━━━━━━━━━━━━━━━━━━━━━━━ */
  .ages-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--fog);
    border: 1px solid var(--fog);
  }

  .age-card {
    width: 100%;
    border: 0;
    background: var(--void);
    padding: 1.5rem 1.3rem;
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 200px;
    cursor: pointer;
    transition: background 0.2s;
    text-align: left;
  }

  .age-card:hover,
  .age-card:focus-visible,
  .age-card[aria-expanded="true"] { background: var(--ink); }

  .age-card:focus-visible {
    outline: 2px solid var(--glow);
    outline-offset: -2px;
  }

  .age-card[aria-expanded="true"] { border-top: 2px solid var(--glow); }

  .age-num {
    font-size: 0.56rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--ash);
    margin-bottom: 0.5rem;
  }

  .age-card.open-now .age-num { color: var(--glow); }

  .age-name {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--bone);
    line-height: 1.2;
    margin-bottom: 0.5rem;
  }

  .age-genre {
    display: block;
    font-size: 0.7rem;
    color: var(--ash);
    font-style: italic;
    line-height: 1.45;
    flex: 1;
  }

  .age-open-mark {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    font-size: 0.5rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--glow);
    border: 1px solid var(--threat);
    padding: 0.15rem 0.4rem;
  }

  .age-action {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1.2rem;
    font-size: 0.56rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--glow);
    opacity: 0;
    transition: opacity 0.2s;
  }

  .age-action::after { content: '↗'; font-size: 0.7rem; }
  .age-card[aria-expanded="true"] .age-action::after { content: '✕'; }
  .age-card:hover .age-action,
  .age-card:focus-visible .age-action,
  .age-card[aria-expanded="true"] .age-action { opacity: 1; }

  /* AGE MODAL */
  .age-modal-open { overflow: hidden; }
  .age-modal-shell[hidden] { display: none; }
  .age-modal-shell {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: grid;
    place-items: center;
    padding: 2rem;
  }

  .age-modal-overlay {
    position: absolute;
    inset: 0;
    background: rgba(5,4,6,0.88);
    backdrop-filter: blur(4px);
  }

  .age-modal {
    position: relative;
    z-index: 1;
    width: min(880px, 100%);
    max-height: min(85vh, 900px);
    overflow: auto;
    padding: 1.75rem;
    border: 1px solid var(--fog);
    background: var(--ink);
    box-shadow: 0 32px 80px rgba(0,0,0,0.7);
    outline: none;
  }

  .age-modal-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 2rem;
    height: 2rem;
    border: 1px solid var(--threat);
    background: var(--void);
    color: var(--bone);
    font-size: 0.9rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }

  .age-modal-close:hover { background: var(--threat); }

  .age-panel-head {
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
    align-items: flex-start;
    margin-bottom: 1.2rem;
  }

  .age-panel-label {
    font-size: 0.54rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ash);
    margin-bottom: 0.3rem;
  }

  .age-modal h3 {
    font-family: var(--font-display);
    font-size: 1.6rem;
    color: var(--bone);
    margin: 0;
    line-height: 1.1;
  }

  .age-status {
    flex-shrink: 0;
    padding: 0.3rem 0.5rem;
    border: 1px solid var(--threat);
    color: var(--glow);
    font-size: 0.56rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    line-height: 1.4;
    max-width: 180px;
    text-align: right;
  }

  .age-chips {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    margin-bottom: 1px;
    background: var(--fog);
    border: 1px solid var(--fog);
  }

  .age-chips div { background: var(--void); padding: 0.8rem; min-width: 0; }

  .age-chips dt,
  .age-field span {
    display: block;
    font-size: 0.52rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ash);
    margin-bottom: 0.3rem;
  }

  .age-chips dd {
    margin: 0;
    color: var(--bone-dim);
    font-size: 0.7rem;
    line-height: 1.45;
  }

  .age-fields {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--fog);
    border: 1px solid var(--fog);
    border-top: none;
    margin-bottom: 1px;
  }

  .age-field { background: var(--void); padding: 1rem; min-width: 0; }
  .age-field--wide { grid-column: span 2; }
  .age-field p { margin: 0; color: var(--bone-dim); font-size: 0.74rem; line-height: 1.55; }

  .age-lineages {
    border: 1px solid var(--fog);
    border-top: none;
    background: var(--void);
    padding: 1rem;
    max-height: 10rem;
    overflow: auto;
  }

  .age-lineages span {
    display: block;
    margin-bottom: 0.4rem;
    font-size: 0.52rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ash);
  }

  .age-lineages p { margin: 0; color: var(--bone-dim); font-size: 0.74rem; line-height: 1.65; }

  /* ━━━━━━━━━━━━━━━━━━━━━━━━
     MÜTVIA PREVIEW
  ━━━━━━━━━━━━━━━━━━━━━━━━ */
  .mutvia-preview {
    background: linear-gradient(to bottom, var(--void) 0%, #0e0b10 40%, var(--void) 100%);
    border-top: 1px solid rgba(196,80,30,0.2);
    border-bottom: 1px solid rgba(196,80,30,0.2);
    padding: 5rem clamp(1.5rem, 5vw, 3rem);
    position: relative;
    overflow: hidden;
  }

  .mutvia-preview::before {
    content: '';
    position: absolute;
    top: 0; right: 0;
    width: 60%;
    height: 100%;
    background: radial-gradient(ellipse 50% 60% at 80% 30%, rgba(196,80,30,0.07), transparent 70%);
    pointer-events: none;
  }

  .mutvia-preview-inner {
    max-width: 1060px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .mutvia-intro {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    max-width: 680px;
    margin-bottom: 3rem;
  }

  .mutvia-logo {
    width: clamp(160px, 20vw, 280px);
    height: auto;
    filter: drop-shadow(0 0 30px rgba(196,80,30,0.2));
    margin-bottom: 0.5rem;
  }

  .mutvia-label {
    font-size: 0.58rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--glow);
  }

  .mutvia-heading {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 400;
    color: var(--bone);
    line-height: 1.1;
    margin: 0;
  }

  .mutvia-desc {
    font-size: clamp(0.9rem, 1.5vw, 1.05rem);
    color: var(--bone-dim);
    line-height: 1.75;
    max-width: 600px;
    margin: 0;
  }

  .mutvia-verse {
    border-left: 2px solid var(--glow);
    padding: 0.75rem 0 0.75rem 1.5rem;
    margin: 0.5rem 0 0;
    font-style: italic;
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--ash);
    line-height: 1.9;
  }

  .mutvia-verse em { display: block; }

  /* MAP STRIP */
  .mutvia-map-strip {
    margin: 0 0 3rem;
    border: 1px solid var(--fog);
    overflow: hidden;
  }

  .mutvia-map-placeholder {
    height: 300px;
    background: linear-gradient(135deg, var(--ink), #0d0c0f);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .map-placeholder-label {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--fog);
    border: 1px dashed var(--fog);
    padding: 0.75rem 1.5rem;
  }

  /* BEAT CARDS */
  .mutvia-beats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--fog);
    border: 1px solid var(--fog);
    margin-bottom: 3rem;
  }

  .beat-card {
    background: var(--void);
    padding: 1.75rem 1.5rem;
    transition: background 0.2s;
    position: relative;
  }

  .beat-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 2px;
    height: 0;
    background: var(--glow);
    transition: height 0.3s ease;
  }

  .beat-card:hover { background: var(--ink); }
  .beat-card:hover::before { height: 100%; }

  .beat-tag {
    font-size: 0.52rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--glow);
    margin-bottom: 0.4rem;
  }

  .beat-label {
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ash);
    margin-bottom: 0.75rem;
  }

  .beat-heading {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--bone);
    line-height: 1.25;
    margin: 0 0 0.75rem;
  }

  .beat-body {
    font-size: 0.8rem;
    color: var(--ash);
    line-height: 1.7;
    margin: 0;
  }

  .mutvia-cta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .mutvia-cta-note {
    font-size: 0.68rem;
    color: var(--ash);
    font-style: italic;
    margin: 0;
  }

