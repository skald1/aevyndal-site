---
import HomeLayout from "../layouts/HomeLayout.astro";

const ages = [
  {
    ordinal: "First Age",
    name: "Age of Creation",
    genre: "Creation myth, fae fantasy, primordial wonder.",
    continents: "Pre-continental / world still forming.",
    scope: "No formal countries.",
    lineages: "Italti, early th'il precursors, primal spirits, divine-touched beings.",
    notableLineages: "Italti.",
    magic: "Elemental forces are raw, immediate, and mythic.",
    technology: "Pre-civilizational.",
    status: "Mythic foundation.",
    regions: "Felwiddel, early Elydris, primordial Vaunor.",
    support: "Lore foundation, creation myths, metaphysical reference.",
    hook: "Stories about first names, first bargains, first betrayals, and the shaping of reality.",
  },
  {
    ordinal: "Second Age",
    name: "Age of Italti",
    genre: "Sword-and-sandals mythic fantasy, empire, divine ruin.",
    continents: "Erinnal, Maj'ridal, Aris.",
    scope: "Early civilizations, sacred territories, city-states, proto-kingdoms.",
    lineages: "Italti, Children of the Italti, early mortal peoples.",
    notableLineages: "Korvad'an, Odoko, Maraki, Geraki, Sadrath.",
    magic: "High, dangerous, and poorly understood by mortals.",
    technology: "Bronze / early classical.",
    status: "Partially developed.",
    regions: "Italti ruins, early sacred sites, Aris.",
    support: "Lore foundation, ancient ruins, historical mysteries.",
    hook: "Mortal cultures rise beneath the shadow of beings too powerful to fully understand.",
  },
  {
    ordinal: "Third Age",
    name: "Age of Expansion",
    genre: "High fantasy, exploration, kingdoms, trade, cultural formation.",
    continents: "Erinnal, Maj'ridal, Aris.",
    scope: "Nations, roads, temples, schools, ports, and trade routes expand.",
    lineages: "Most modern kin-groups are present or emerging.",
    notableLineages: "Major mortal lineages and regional cultures become recognizable.",
    magic: "Known, studied, feared, and institutionalized in places.",
    technology: "Medieval / high fantasy.",
    status: "Broadly outlined.",
    regions: "Wyth Tyr'il, Erinnal, Maj'ridal.",
    support: "Atlas material, historical reference, campaign foundations.",
    hook: "A world becoming legible, dangerous, ambitious, and connected.",
  },
  {
    ordinal: "Fourth Age",
    name: "Age of Shadowed Crowns",
    genre: "Dark medieval fantasy, folklore horror, feudal pressure.",
    continents: "Erinnal, Maj'ridal, Aris.",
    scope: "Broad national and regional structure; feudal states, isolated settlements, contested territories.",
    lineages: "Adri'il, Fayd'il, Lithar'il, Myrad'il, Ryal'il, Slindar'il, Theran'il, Vaud'il, Human, Umbran, Vivashan, Velasyrn, Karuun, Guelt, Gol, Gnome, Igyrlin, Tirfolk, Korvad'an, Odoko, Maraki, Geraki, Sadrath, Sheydra, Rech, Thiraf, Varul, Kobold, Goblin, T'nao, Gulvani.",
    notableLineages: "Sheydra and several post-Italti mortal peoples are fully active in play.",
    magic: "Rare, costly, feared, and culturally distorted.",
    technology: "Medieval / dark fantasy.",
    status: "Highly developed.",
    regions: "Mutvia, Krethavar, Wyth Tyr'il, Aris.",
    support: "Pathfinder 2e Remaster material, adventures, maps, actual-play support, regional lore.",
    hook: "Villages survive between noble power, superstition, old magic, hunger, and things in the woods.",
    open: true,
  },
  {
    ordinal: "Fifth Age",
    name: "Age of Ruin",
    genre: "Post-apocalyptic fantasy, survival, rewilding, broken kingdoms.",
    continents: "Erinnal, Maj'ridal, Aris.",
    scope: "Collapsed states, isolated settlements, ruin-zones, survival territories.",
    lineages: "All major mortal lineages plus created beings such as Wrought and Fifth Age Automatons.",
    notableLineages: "Wrought, Fifth Age Automatons.",
    magic: "Rare, dangerous, half-remembered, and often misused.",
    technology: "Post-collapse / scavenged / early steampunk remnants.",
    status: "Active development.",
    regions: "Mutvia aftermath regions, ruin settlements, rewilded territories.",
    support: "Campaign concepts, survival play, creature design, regional expansion.",
    hook: "The old world failed. The new one is feral, hungry, and full of things people were never meant to wake.",
  },
  {
    ordinal: "Sixth Age",
    name: "Age of Smoke and Secrets",
    genre: "Industrial fantasy, gothic science, occult conspiracy.",
    continents: "Erinnal, Maj'ridal, Aris, and expanding global networks.",
    scope: "Industrial nations, colonial pressure, rail corridors, factory cities, academic centers.",
    lineages: "Established peoples adapting to industry, class pressure, and hidden experimentation.",
    notableLineages: "Experimental created beings, altered bloodlines, early artificial life.",
    magic: "Studied, restricted, commodified, and hidden behind institutions.",
    technology: "Industrial / gaslight / early modern science.",
    status: "Outlined / future development.",
    regions: "Industrial cities, secret societies, universities, occult laboratories.",
    support: "Conceptual framework, future campaign support.",
    hook: "Science, magic, religion, and industry stop pretending they are separate forces.",
  },
  {
    ordinal: "Seventh Age",
    name: "Syndicate Age",
    genre: "Dystopian dark science fiction, corporate rule, grimdark futurism.",
    continents: "Global and intersystem.",
    scope: "Dominions, megastructures, surveillance states, corporate territories.",
    lineages: "Modern peoples, androids, altered humans, corporate-designed bodies.",
    notableLineages: "Androids and engineered peoples.",
    magic: "Engineered, exploited, suppressed, or converted into systems of control.",
    technology: "Hypertech / cyberpunk / dark science fiction.",
    status: "Conceptual but structurally important.",
    regions: "Dominions, corporate arcologies, surveillance states, off-world infrastructure.",
    support: "Dominion lore, future campaign structure, dystopian reference.",
    hook: "The world survives, but ownership replaces stewardship.",
  },
  {
    ordinal: "Eighth Age",
    name: "Brightpunk Age",
    genre: "Brightpunk, post-dystopian recovery, science-magic-faith integration.",
    continents: "Global and intersystem.",
    scope: "Reclaimed cities, restored biomes, new alliances, post-Dominion futures.",
    lineages: "Broadest lineage access; cultural, technological, and metaphysical synthesis.",
    notableLineages: "Future-facing created and restored peoples as needed.",
    magic: "Integrated into civic life, ecological restoration, science, medicine, and spiritual practice.",
    technology: "Brightpunk / ecological futurism / advanced synthesis.",
    status: "Developed as future-facing thesis.",
    regions: "Reclaimed cities, restored wilds, intersystem routes, post-Syndicate communities.",
    support: "Brightpunk preview material, actual-play future, worldbuilding thesis.",
    hook: "The question is no longer whether civilization can survive. It is what kind of civilization deserves to.",
  },
];
---

<HomeLayout title="Ævyndal" description="Forty years ago someone wanted to know what was outside the dungeon. The world that question built is yours now.">

  <!-- NAV handled by HomeLayout -->

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <p class="hero-eyebrow">Grimwell Studio · An Original Universe</p>
      <h1 class="hero-title">
        Forty years ago<br/>I wanted to know<br/>what was <em>outside<br/>the dungeon.</em>
      </h1>
      <p class="hero-hook">I'm still finding out. <strong>Now so can you.</strong></p>
      <div class="hero-cta">
        <a href="#enter" class="btn-primary">Begin Your Story</a>
        <a href="#ages" class="btn-ghost">Explore the World</a>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- AGES -->
  <section class="section" id="ages">
    <div class="section-inner">
      <div class="section-head">
        <h2 class="section-title">The Eight Ages</h2>
        <div class="section-rule"></div>
      </div>
      <p class="section-sub">One world. Eight epochs. Each carries its own genre, its own relationship to magic, its own version of what survival costs. The Fourth Age is open now.</p>
      <div class="ages-grid">
        {ages.map((age) => (
          <details class="age-panel">
            <summary class="age-card">
              {age.open && <span class="age-open-mark">Open Now</span>}
              <span class="age-num">{age.ordinal}</span>
              <span class="age-name">{age.name}</span>
              <span class="age-genre">{age.genre}</span>
              <span class="age-action">Explore this Age</span>
            </summary>
            <div class="age-panel-body">
              <div class="age-panel-head">
                <div>
                  <div class="age-panel-label">Age Name</div>
                  <h3>{age.name}</h3>
                </div>
                <div class="age-status">{age.status}</div>
              </div>

              <dl class="age-chips" aria-label={`${age.name} quick comparison`}>
                <div>
                  <dt>Continents</dt>
                  <dd>{age.continents}</dd>
                </div>
                <div>
                  <dt>Scope</dt>
                  <dd>{age.scope}</dd>
                </div>
                <div>
                  <dt>Magic</dt>
                  <dd>{age.magic}</dd>
                </div>
                <div>
                  <dt>Technology</dt>
                  <dd>{age.technology}</dd>
                </div>
              </dl>

              <div class="age-fields">
                <div class="age-field">
                  <span>Genre / Play Mode</span>
                  <p>{age.genre}</p>
                </div>
                <div class="age-field">
                  <span>Countries / Political Scope</span>
                  <p>{age.scope}</p>
                </div>
                <div class="age-field">
                  <span>New or Notable Lineages Introduced</span>
                  <p>{age.notableLineages}</p>
                </div>
                <div class="age-field">
                  <span>Featured Regions</span>
                  <p>{age.regions}</p>
                </div>
                <div class="age-field">
                  <span>Current Play Support</span>
                  <p>{age.support}</p>
                </div>
                <div class="age-field age-field--wide">
                  <span>Play Hook</span>
                  <p>{age.hook}</p>
                </div>
              </div>

              <details class="age-subpanel">
                <summary>Lineages Available</summary>
                <p>{age.lineages}</p>
              </details>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- WORLDS -->
  <section class="section" id="worlds">
    <div class="section-inner">
      <div class="section-head">
        <h2 class="section-title">The Worlds</h2>
        <div class="section-rule"></div>
      </div>
      <p class="section-sub">Sythlia's creation spans more than one world. The ages run through all of it.</p>
      <div class="worlds-grid">
        <div class="world-card">
          <div class="world-card-eye">Primary World · Active</div>
          <div class="world-card-name">Elydris</div>
          <div class="world-card-desc">The planet. Three continents shaped and reshaped by tectonic drift across the ages. Local star: Aryos. All current content originates here.</div>
        </div>
        <div class="world-card locked">
          <div class="world-card-eye">Secondary World · Locked</div>
          <div class="world-card-name">Felwiddel</div>
          <div class="world-card-desc">Planet of fey. Fey exist throughout Sythlia's creation, but nowhere are they more concentrated than here. Not yet available.</div>
        </div>
      </div>
      <div class="sub-head">
        <span class="sub-head-title">Continents of Elydris</span>
      </div>
      <div class="continents-grid">
        <div class="continent-card">
          <div class="continent-card-label">Primary Continent · Active</div>
          <div class="continent-card-name">Erinnal</div>
          <div class="continent-card-meta">43 countries · The home of adventure and the birthplace of the setting</div>
        </div>
        <div class="continent-card locked">
          <div class="continent-card-label">Second Continent · Locked</div>
          <div class="continent-card-name">Majri'dal</div>
          <div class="continent-card-meta">23 countries · Named, real, not yet available</div>
        </div>
        <div class="continent-card reserved">
          <div class="continent-card-label">Third Continent · Reserved</div>
          <div class="continent-card-name">Aris</div>
          <div class="continent-card-meta">The long destination · Available when the world is ready for it</div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- LINEAGES -->
  <section class="section" id="lineages">
    <div class="section-inner">
      <div class="section-head">
        <h2 class="section-title">Thirty-Three Peoples</h2>
        <div class="section-rule"></div>
      </div>
      <p class="section-sub">No elves. No dwarves. No borrowed mythology. Thirty-three original peoples in seven families, each with their own origins, their own history, their own relationship to the eight elements.</p>
      <div class="lineage-grid">
        <div class="family-card">
          <div class="family-name">Th'il</div>
          <div class="family-peoples">Adri'il · Fayd'il · Lithar'il · Myrad'il · Ryal'il · Slindar'il · Theran'il · Vaud'il</div>
          <span class="family-tag">8 Peoples</span>
        </div>
        <div class="family-card">
          <div class="family-name">Dranorvauri</div>
          <div class="family-peoples">Gnome · Gol · Guelt · Igyrlin · Karuun · Tirfolk</div>
          <span class="family-tag">6 Peoples</span>
        </div>
        <div class="family-card">
          <div class="family-name">Children of the Italti</div>
          <div class="family-peoples">Geraki · Korva'dan · Maraki · Odoko · Quirrin · Sadrath</div>
          <span class="family-tag">6 Peoples · Korva'dan available</span>
        </div>
        <div class="family-card">
          <div class="family-name">Klane</div>
          <div class="family-peoples">Human · Umbran · Vivashan</div>
          <span class="family-tag">3 Peoples</span>
        </div>
        <div class="family-card">
          <div class="family-name">Evolved</div>
          <div class="family-peoples">Gulvani · Thiraf · Värul</div>
          <span class="family-tag">3 Peoples</span>
        </div>
        <div class="family-card">
          <div class="family-name">Children of the Dreg'n</div>
          <div class="family-peoples">Goblin · Kobold · Kotera · T'nao</div>
          <span class="family-tag">4 Peoples</span>
        </div>
        <div class="family-card">
          <div class="family-name">Wrought</div>
          <div class="family-peoples">Rech · Sheydra · Fifth Age Automaton</div>
          <span class="family-tag">3 Peoples</span>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- VOTE -->
  <section class="vote">
    <div class="vote-inner">
      <p class="vote-eye">Community · What Opens Next</p>
      <h2 class="vote-title">The world grows in response to its inhabitants.</h2>
      <p class="vote-desc">Seven ages are locked. Two continents are waiting. You decide what opens next. Every sprint is driven by the people who live here.</p>
      <div class="vote-opts">
        <label class="vote-opt">
          <input type="radio" name="vote" value="age2" />
          <span class="vote-opt-name">Second Age</span>
          <span class="vote-opt-genre">Chaos &amp; God-Kings</span>
        </label>
        <label class="vote-opt">
          <input type="radio" name="vote" value="age3" />
          <span class="vote-opt-name">Third Age</span>
          <span class="vote-opt-genre">Expansion of Empires</span>
        </label>
        <label class="vote-opt">
          <input type="radio" name="vote" value="majridal" />
          <span class="vote-opt-name">Majri'dal</span>
          <span class="vote-opt-genre">Second Continent</span>
        </label>
      </div>
      <a href="#enter" class="btn-primary">Vote &amp; Join the List</a>
    </div>
  </section>

  <!-- MAILING LIST -->
  <section class="ml" id="enter">
    <div class="ml-inner">
      <div class="ml-mark">✦</div>
      <h2 class="ml-title">You never have to start over again.</h2>
      <p class="ml-desc">Ævyndal solves the experienced GM's grief over worlds that die with campaigns. Your characters, your communities, your stories — they persist here. Be here when the next door opens.</p>
      <form
        action="https://buttondown.com/api/emails/embed-subscribe/sjvox"
        method="post"
        class="ml-form"
      >
        <label for="bd-email" class="sr-only">Your email address</label>
        <input class="ml-input" type="email" name="email" id="bd-email" placeholder="your@email.com" required />
        <button class="ml-btn" type="submit">Enter</button>
      </form>
      <p class="ml-note">No noise. Only when something opens.</p>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <span class="footer-mark">Ævyndal</span>
    <nav class="footer-nav">
      <a href="https://evindale.com/atlas">Atlas</a>
      <span>·</span>
      <a href="https://evindale.com/gods">Deities</a>
      <span>·</span>
      <a href="https://evindale.com/lineages">Lineages</a>
      <span>·</span>
      <a href="https://discord.gg/kZetsKk">Discord</a>
    </nav>
    <span class="footer-copy">© SJ Kraus</span>
  </footer>

</HomeLayout>

<style>
  :root {
    --void:          #09080A;
    --ink:           #1A1614;
    --haze:          #2E2926;
    --fog:           #3A3530;
    --ash:           #5C5650;
    --bone-dim:      #8A837A;
    --bone:          #D0C9BC;
    --threat:        #8B3218;
    --glow:          #C4501E;
    --font-display:  'Crimson Text', Georgia, serif;
    --font-body:     'Lora', Georgia, serif;
  }

  /* ═══ HERO ═══ */
  .hero {
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    padding: 0 3rem 7rem;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -10%; right: 5%;
    width: 55vw; height: 100vh;
    background: radial-gradient(ellipse 50% 70% at 60% 30%,
      rgba(196,80,30,0.18) 0%,
      rgba(139,50,24,0.08) 40%,
      transparent 70%);
    pointer-events: none;
  }
  .hero::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 30vh;
    background: linear-gradient(to top, var(--void) 0%, transparent 100%);
    pointer-events: none;
    z-index: 1;
  }
  .hero-inner { position: relative; z-index: 2; max-width: 740px; }

  .hero-eyebrow {
    font-size: 0.65rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--glow);
    margin-bottom: 2rem;
    opacity: 0;
    animation: rise 0.9s ease forwards 0.3s;
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 7vw, 6rem);
    font-weight: 400;
    line-height: 1.0;
    color: var(--bone);
    margin-bottom: 2rem;
    opacity: 0;
    animation: rise 1s ease forwards 0.5s;
  }
  .hero-title em { font-style: italic; color: var(--bone-dim); }
  .hero-hook {
    font-family: var(--font-display);
    font-size: clamp(1rem, 2vw, 1.3rem);
    font-style: italic;
    color: var(--ash);
    max-width: 480px;
    margin-bottom: 3rem;
    line-height: 1.6;
    opacity: 0;
    animation: rise 1s ease forwards 0.7s;
  }
  .hero-hook strong { color: var(--bone); font-style: normal; }
  .hero-cta {
    display: flex;
    gap: 2rem;
    align-items: center;
    flex-wrap: wrap;
    opacity: 0;
    animation: rise 1s ease forwards 0.9s;
  }

  @keyframes rise {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ═══ BUTTONS ═══ */
  .btn-primary {
    display: inline-block;
    padding: 0.75rem 1.8rem;
    background: var(--threat);
    color: var(--bone);
    font-family: var(--font-body);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid var(--glow);
    transition: background 0.25s;
  }
  .btn-primary:hover { background: var(--glow); }
  .btn-ghost {
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ash);
    text-decoration: none;
    border-bottom: 1px solid var(--fog);
    padding-bottom: 0.1rem;
    transition: color 0.25s, border-color 0.25s;
  }
  .btn-ghost:hover { color: var(--bone); border-color: var(--ash); }

  /* ═══ DIVIDER ═══ */
  .divider {
    height: 1px;
    margin: 0 3rem;
    background: linear-gradient(to right, transparent, var(--threat), transparent);
    opacity: 0.4;
  }

  /* ═══ SECTIONS ═══ */
  .section { padding: 6rem 3rem; }
  .section-inner { max-width: 1060px; margin: 0 auto; }
  .section-head {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    margin-bottom: 0.8rem;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: 1.9rem;
    font-weight: 600;
    color: var(--bone);
    line-height: 1;
    white-space: nowrap;
  }
  .section-rule { flex: 1; height: 1px; background: var(--fog); }
  .section-sub {
    font-size: 0.82rem;
    color: var(--ash);
    font-style: italic;
    max-width: 520px;
    margin-bottom: 2.5rem;
    line-height: 1.6;
  }

  /* ═══ AGES ═══ */
  .ages-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--fog);
    border: 1px solid var(--fog);
  }
  .age-panel {
    background: var(--void);
    min-width: 0;
  }
  .age-panel[open] {
    grid-column: 1 / -1;
    background: var(--ink);
  }
  .age-panel > summary::-webkit-details-marker { display: none; }
  .age-panel > summary::marker { content: ''; }
  .age-card {
    background: var(--void);
    padding: 1.5rem 1.3rem;
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 210px;
    cursor: pointer;
    transition: background 0.25s;
    list-style: none;
    text-align: left;
  }
  .age-card:hover,
  .age-card:focus-visible,
  .age-panel[open] .age-card { background: var(--ink); }
  .age-card:focus-visible {
    outline: 2px solid var(--glow);
    outline-offset: -2px;
  }
  .age-panel[open] .age-card {
    min-height: 0;
    border-top: 2px solid var(--glow);
  }
  .age-num {
    font-size: 0.58rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ash);
    margin-bottom: 0.5rem;
  }
  .age-open-mark ~ .age-num { color: var(--glow); }
  .age-name {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--bone);
    line-height: 1.2;
    margin-bottom: 0.5rem;
  }
  .age-genre {
    display: block;
    font-size: 0.72rem;
    color: var(--ash);
    font-style: italic;
    line-height: 1.45;
  }
  .age-panel[open] .age-genre { color: var(--bone-dim); }
  .age-open-mark {
    position: absolute;
    top: 0.8rem; right: 0.8rem;
    font-size: 0.52rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--glow);
    border: 1px solid var(--threat);
    padding: 0.18rem 0.45rem;
  }
  .age-action {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    margin-top: auto;
    padding-top: 1.2rem;
    font-size: 0.58rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--glow);
  }
  .age-action::after {
