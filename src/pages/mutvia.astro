<style>
/* ============================================
   MÜTVIA PAGE — EVINDALE.COM
   Palette: Void / Cold / Eastern European Gothic
   ============================================ */

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --void: #09080A;
  --ink: #0f0d11;
  --bruised: #2A2440;
  --bruised-mid: #1e1a30;
  --cold-bone: #D0C9BC;
  --cold-ash: #5C5650;
  --threat: #8B3218;
  --blood-orange: #C4501E;
  --silver: #9aa0a8;
  --silver-light: #c8cdd4;
  --moss: #2a3520;
  --font-display: 'Cinzel Decorative', serif;
  --font-heading: 'Cinzel', serif;
  --font-body: 'EB Garamond', serif;
}

html { scroll-behavior: smooth; }

body {
  background-color: var(--void);
  color: var(--cold-bone);
  font-family: var(--font-body);
  font-size: 18px;
  line-height: 1.75;
  overflow-x: hidden;
}

/* ============================================
   HERO
   ============================================ */

.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  inset: 0;
  background-image: url('https://evindale.com/wp-content/uploads/2024/05/DarkGothicCastle1920x1080.webp');
  background-size: cover;
  background-position: center top;
  background-repeat: no-repeat;
  filter: brightness(0.35) saturate(0.6);
  z-index: 0;
}

.hero-bg::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    transparent 0%,
    transparent 50%,
    rgba(9,8,10,0.7) 80%,
    var(--void) 100%
  );
}

.hero-content {
  position: relative;
  z-index: 1;
  text-align: center;
  padding: 2rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rem;
}

.hero-logo {
  width: min(380px, 80vw);
  height: auto;
  filter: drop-shadow(0 0 40px rgba(196,80,30,0.25));
  animation: fadeInDown 1.2s ease both;
}

.hero-tagline {
  font-family: var(--font-heading);
  font-size: clamp(0.8rem, 2vw, 1rem);
  letter-spacing: 0.35em;
  text-transform: uppercase;
  color: var(--silver);
  animation: fadeInUp 1.2s ease 0.3s both;
}

.hero-verse {
  font-family: var(--font-body);
  font-style: italic;
  font-size: clamp(1rem, 2.5vw, 1.2rem);
  color: var(--cold-ash);
  line-height: 2;
  animation: fadeInUp 1.2s ease 0.5s both;
  max-width: 500px;
}

.hero-verse em {
  display: block;
}

.hero-scroll-hint {
  position: absolute;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%);
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  color: var(--cold-ash);
  font-family: var(--font-heading);
  font-size: 0.65rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  animation: fadeIn 2s ease 1.5s both;
}

.scroll-arrow {
  width: 1px;
  height: 40px;
  background: linear-gradient(to bottom, var(--blood-orange), transparent);
  animation: scrollPulse 2s ease infinite;
}

/* ============================================
   STAT BLOCK
   ============================================ */

.stat-block {
  background: linear-gradient(135deg, var(--bruised-mid), var(--ink));
  border: 1px solid rgba(196,80,30,0.2);
  border-left: 3px solid var(--blood-orange);
  max-width: 900px;
  margin: -2rem auto 0;
  position: relative;
  z-index: 2;
  padding: 2rem 2.5rem;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 1rem 2rem;
}

.stat-item {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}

.stat-label {
  font-family: var(--font-heading);
  font-size: 0.6rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--blood-orange);
}

.stat-value {
  font-family: var(--font-body);
  font-size: 0.95rem;
  color: var(--cold-bone);
}

/* ============================================
   IN-PAGE NAV
   ============================================ */

.page-nav {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(9,8,10,0.95);
  backdrop-filter: blur(8px);
  border-bottom: 1px solid rgba(196,80,30,0.2);
  padding: 0;
  overflow-x: auto;
  scrollbar-width: none;
}

.page-nav::-webkit-scrollbar { display: none; }

.page-nav-inner {
  display: flex;
  align-items: center;
  gap: 0;
  min-width: max-content;
  padding: 0 2rem;
}

.page-nav a {
  font-family: var(--font-heading);
  font-size: 0.6rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--cold-ash);
  text-decoration: none;
  padding: 1rem 1.2rem;
  border-bottom: 2px solid transparent;
  transition: color 0.2s, border-color 0.2s;
  white-space: nowrap;
}

.page-nav a:hover {
  color: var(--cold-bone);
  border-bottom-color: var(--blood-orange);
}

/* ============================================
   MAIN LAYOUT
   ============================================ */

.page-content {
  max-width: 860px;
  margin: 0 auto;
  padding: 4rem 2rem 8rem;
}

/* ============================================
   SECTION STRUCTURE
   ============================================ */

.atlas-section {
  margin-bottom: 5rem;
  scroll-margin-top: 60px;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  margin-bottom: 2rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid rgba(196,80,30,0.25);
}

.section-header::before {
  content: '';
  display: block;
  width: 3px;
  height: 2rem;
  background: var(--blood-orange);
  flex-shrink: 0;
}

h2.section-title {
  font-family: var(--font-heading);
  font-size: clamp(1.1rem, 3vw, 1.4rem);
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--cold-bone);
  margin: 0;
}

h3.subsection-title {
  font-family: var(--font-heading);
  font-size: clamp(0.9rem, 2.5vw, 1.05rem);
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--silver-light);
  margin: 2.5rem 0 1rem;
  padding-left: 1rem;
  border-left: 2px solid var(--bruised);
}

h4.sub-subsection-title {
  font-family: var(--font-heading);
  font-size: 0.85rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--silver);
  margin: 2rem 0 0.75rem;
}

h5.family-title {
  font-family: var(--font-heading);
  font-size: 1rem;
  letter-spacing: 0.08em;
  color: var(--cold-bone);
  margin: 0 0 0.25rem;
}

/* ============================================
   PROSE
   ============================================ */

p {
  margin-bottom: 1.25rem;
  color: var(--cold-bone);
  font-size: 1rem;
}

p:last-child { margin-bottom: 0; }

em { color: var(--silver-light); }

strong { color: #fff; font-weight: 500; }

/* ============================================
   PULL QUOTE / VERSE
   ============================================ */

.pull-quote {
  font-family: var(--font-body);
  font-style: italic;
  font-size: 1.15rem;
  color: var(--cold-ash);
  border-left: 2px solid var(--blood-orange);
  padding: 1rem 0 1rem 2rem;
  margin: 2.5rem 0;
  line-height: 1.9;
}

.pull-quote cite {
  display: block;
  font-size: 0.8rem;
  font-style: normal;
  font-family: var(--font-heading);
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--cold-ash);
  margin-top: 0.75rem;
}

.verse-block {
  font-family: var(--font-body);
  font-style: italic;
  font-size: 1rem;
  color: var(--cold-ash);
  text-align: center;
  padding: 2rem;
  line-height: 2.2;
  background: linear-gradient(to bottom, transparent, rgba(42,36,64,0.15), transparent);
}

.verse-block em { display: block; }

/* ============================================
   CALLOUT / WARNING BOX
   ============================================ */

.callout {
  background: rgba(42,36,64,0.3);
  border: 1px solid rgba(196,80,30,0.2);
  border-left: 3px solid var(--threat);
  padding: 1.5rem 2rem;
  margin: 2rem 0;
  font-size: 0.95rem;
}

.callout-label {
  font-family: var(--font-heading);
  font-size: 0.6rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--threat);
  margin-bottom: 0.5rem;
}

/* ============================================
   GEOGRAPHY LOCATIONS
   ============================================ */

.location-entry {
  margin-bottom: 2rem;
  padding-bottom: 2rem;
  border-bottom: 1px solid rgba(92,86,80,0.2);
}

.location-entry:last-child {
  border-bottom: none;
}

.location-name {
  font-family: var(--font-heading);
  font-size: 0.85rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--silver-light);
  margin-bottom: 0.5rem;
}

.location-translation {
  font-family: var(--font-body);
  font-style: italic;
  font-size: 0.85rem;
  color: var(--cold-ash);
  margin-bottom: 0.75rem;
}

/* ============================================
   HIERARCHY TABLE
   ============================================ */

.hierarchy-table {
  width: 100%;
  border-collapse: collapse;
  margin: 1.5rem 0;
  font-size: 0.9rem;
}

.hierarchy-table th {
  font-family: var(--font-heading);
  font-size: 0.6rem;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--blood-orange);
  text-align: left;
  padding: 0.75rem 1rem;
  border-bottom: 1px solid rgba(196,80,30,0.3);
}

.hierarchy-table td {
  padding: 0.75rem 1rem;
  border-bottom: 1px solid rgba(92,86,80,0.15);
  vertical-align: top;
}

.hierarchy-table td:first-child {
  font-family: var(--font-heading);
  font-size: 0.8rem;
  letter-spacing: 0.08em;
  color: var(--silver-light);
  white-space: nowrap;
  width: 30%;
}

.hierarchy-table td:last-child {
  color: var(--cold-bone);
  font-size: 0.9rem;
}

.hierarchy-table tr:last-child td {
  border-bottom: none;
}

/* ============================================
   DRÓSTI FAMILY CARDS
   ============================================ */

.family-card {
  background: linear-gradient(135deg, rgba(42,36,64,0.2), rgba(15,13,17,0.4));
  border: 1px solid rgba(92,86,80,0.2);
  border-top: 2px solid var(--blood-orange);
  padding: 2rem 2.5rem;
  margin-bottom: 2.5rem;
}

.family-header {
  margin-bottom: 1.5rem;
  padding-bottom: 1rem;
  border-bottom: 1px solid rgba(92,86,80,0.2);
}

.family-subtitle {
  font-family: var(--font-body);
  font-style: italic;
  font-size: 0.9rem;
  color: var(--cold-ash);
  margin-top: 0.25rem;
}

/* ============================================
   THREAT ENTRY (Ra'ath)
   ============================================ */

.threat-entry {
  background: linear-gradient(135deg, rgba(139,50,24,0.08), rgba(9,8,10,0.6));
  border: 1px solid rgba(139,50,24,0.3);
  border-left: 3px solid var(--threat);
  padding: 2.5rem;
  margin: 2rem 0;
}

.threat-label {
  font-family: var(--font-heading);
  font-size: 0.6rem;
  letter-spacing: 0.35em;
  text-transform: uppercase;
  color: var(--threat);
  margin-bottom: 1.5rem;
  display: flex;
  align-items: center;
  gap: 1rem;
}

.threat-label::after {
  content: '';
  flex: 1;
  height: 1px;
  background: rgba(139,50,24,0.3);
}

.threat-subsection {
  margin-top: 2rem;
  padding-top: 1.5rem;
  border-top: 1px solid rgba(139,50,24,0.15);
}

.threat-subsection-title {
  font-family: var(--font-heading);
  font-size: 0.7rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(139,50,24,0.8);
  margin-bottom: 1rem;
}

/* ============================================
   DANGER LIST
   ============================================ */

.danger-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  margin: 1.5rem 0;
}

.danger-item {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 1rem;
  padding: 1rem;
  background: rgba(42,36,64,0.15);
  border-left: 2px solid rgba(196,80,30,0.3);
}

.danger-name {
  font-family: var(--font-heading);
  font-size: 0.7rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--silver-light);
  white-space: nowrap;
  padding-top: 0.1rem;
}

.danger-desc {
  font-size: 0.9rem;
  color: var(--cold-bone);
  line-height: 1.6;
}

/* ============================================
   KEY TERMS TABLE
   ============================================ */

.terms-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0;
  margin: 1.5rem 0;
  border: 1px solid rgba(92,86,80,0.2);
}

.term-row {
  display: grid;
  grid-template-columns: 200px 1fr;
  border-bottom: 1px solid rgba(92,86,80,0.15);
}

.term-row:last-child { border-bottom: none; }

.term-word {
  font-family: var(--font-heading);
  font-size: 0.75rem;
  letter-spacing: 0.08em;
  color: var(--silver-light);
  padding: 0.75rem 1rem;
  background: rgba(42,36,64,0.2);
  display: flex;
  align-items: center;
  border-right: 1px solid rgba(92,86,80,0.15);
}

.term-def {
  font-size: 0.85rem;
  color: var(--cold-bone);
  padding: 0.75rem 1rem;
  display: flex;
  align-items: center;
  line-height: 1.5;
}

/* ============================================
   BORDERS SECTION
   ============================================ */

.neighbor-entry {
  display: grid;
  grid-template-columns: 120px 1fr;
  gap: 0;
  margin-bottom: 1.5rem;
  border-bottom: 1px solid rgba(92,86,80,0.15);
  padding-bottom: 1.5rem;
}

.neighbor-entry:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.neighbor-direction {
  font-family: var(--font-heading);
  font-size: 0.65rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--blood-orange);
  padding-top: 0.1rem;
}

.neighbor-content {}

.neighbor-name {
  font-family: var(--font-heading);
  font-size: 0.85rem;
  letter-spacing: 0.08em;
  color: var(--cold-bone);
  margin-bottom: 0.4rem;
}

/* ============================================
   LANGUAGE TABLE
   ============================================ */

.language-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 0.5rem;
  margin: 1.5rem 0;
}

.lang-entry {
  display: grid;
  grid-template-columns: 1fr 1.5fr;
  gap: 0;
  border: 1px solid rgba(92,86,80,0.15);
}

.lang-word {
  font-family: var(--font-heading);
  font-size: 0.7rem;
  letter-spacing: 0.05em;
  color: var(--silver-light);
  padding: 0.6rem 0.75rem;
  background: rgba(42,36,64,0.2);
  display: flex;
  align-items: center;
  border-right: 1px solid rgba(92,86,80,0.15);
  font-style: italic;
}

.lang-def {
  font-size: 0.8rem;
  color: var(--cold-bone);
  padding: 0.6rem 0.75rem;
  display: flex;
  align-items: center;
  line-height: 1.4;
}

/* ============================================
   TONE OF PLAY SECTION
   ============================================ */

.three-truths {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  margin: 2rem 0;
}

.truth-item {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 1.5rem;
  align-items: start;
}

.truth-number {
  font-family: var(--font-display);
  font-size: 2.5rem;
  color: rgba(196,80,30,0.2);
  line-height: 1;
  min-width: 2rem;
  text-align: right;
}

.truth-content strong {
  display: block;
  font-family: var(--font-heading);
  font-size: 0.8rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--silver-light);
  margin-bottom: 0.4rem;
}

.final-line {
  font-family: var(--font-body);
  font-style: italic;
  font-size: 1.3rem;
  color: var(--cold-ash);
  text-align: center;
  padding: 4rem 2rem;
  line-height: 1.8;
  border-top: 1px solid rgba(92,86,80,0.2);
  margin-top: 4rem;
}

/* ============================================
   DIVIDER
   ============================================ */

.ornament-divider {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  margin: 3rem 0;
  color: rgba(92,86,80,0.4);
}

.ornament-divider::before,
.ornament-divider::after {
  content: '';
  flex: 1;
  height: 1px;
  background: rgba(92,86,80,0.2);
}

.ornament-divider span {
  font-family: var(--font-heading);
  font-size: 0.5rem;
  letter-spacing: 0.4em;
  text-transform: uppercase;
  white-space: nowrap;
}

/* ============================================
   ANIMATIONS
   ============================================ */

@keyframes fadeInDown {
  from { opacity: 0; transform: translateY(-20px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes scrollPulse {
  0%, 100% { opacity: 0.3; transform: scaleY(0.8); }
  50% { opacity: 1; transform: scaleY(1); }
}

/* ============================================
   RESPONSIVE
   ============================================ */

@media (max-width: 640px) {
  .stat-block { padding: 1.5rem; }
  .page-content { padding: 2rem 1.25rem 6rem; }
  .family-card { padding: 1.5rem; }
  .threat-entry { padding: 1.5rem; }
  .neighbor-entry { grid-template-columns: 1fr; gap: 0.25rem; }
  .term-row { grid-template-columns: 1fr; }
  .term-word { border-right: none; border-bottom: 1px solid rgba(92,86,80,0.15); }
  .lang-entry { grid-template-columns: 1fr; }
  .lang-word { border-right: none; border-bottom: 1px solid rgba(92,86,80,0.15); }
  .hierarchy-table { font-size: 0.8rem; }
  .hierarchy-table td:first-child { width: auto; white-space: normal; }
}
</style>
</head>
<body>

<!-- ============================================
     HERO
     ============================================ -->
<header class="hero" role="banner">
  <div class="hero-bg" aria-hidden="true"></div>
  <div class="hero-content">
    <img src="https://evindale.com/wp-content/uploads/2024/05/Mutvia-Logo-2024.webp"
         alt="Mütvia — The Land of 1,000 Princes"
         class="hero-logo"
         width="380" height="auto">
    <p class="hero-tagline">Fourth Age &nbsp;·&nbsp; Northern Erinnal &nbsp;·&nbsp; Ævyndal</p>
    <div class="hero-verse" aria-label="Opening verse">
      <em>The wind quiets before it kills.</em>
      <em>The trees lean when no one's looking.</em>
      <em>Say the wrong thing aloud,</em>
      <em>and your milk will curdle before nightfall.</em>
      <em>This is not superstition.</em>
      <em>This is how you survive.</em>
    </div>
  </div>
  <div class="hero-scroll-hint" aria-hidden="true">
    <div class="scroll-arrow"></div>
    <span>Atlas Entry</span>
  </div>
</header>

<!-- ============================================
     STAT BLOCK
     ============================================ -->
<aside class="stat-block" aria-label="Country statistics">
  <div class="stat-item">
    <span class="stat-label">Pronunciation</span>
    <span class="stat-value">MOOT-vee-ah</span>
  </div>
  <div class="stat-item">
    <span class="stat-label">Epithet</span>
    <span class="stat-value">The Land of 1,000 Princes</span>
  </div>
  <div class="stat-item">
    <span class="stat-label">Government</span>
    <span class="stat-value">Fragmented principalities; no central authority</span>
  </div>
  <div class="stat-item">
    <span class="stat-label">Capital</span>
    <span class="stat-value">None</span>
  </div>
  <div class="stat-item">
    <span class="stat-label">Language</span>
    <span class="stat-value">Mütvian</span>
  </div>
