---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAges } from "../../lib/sanity";
import type { Age } from "../../types/content";

export async function getStaticPaths() {
  const ages = await getAges();
  return ages.map((age) => ({ params: { slug: age.slug.current }, props: { age } }));
}

const { age } = Astro.props as { age: Age };
---

<BaseLayout title={`${age.name} — Ævyndal`} description={age.toneStatement ?? age.description ?? age.name}>
  <main class="page-shell age-page" id="main-content" style={`--theme: ${age.color}; --accent: ${age.accentColor}`}>
    <div class="page-shell__inner">
      <p class="eyebrow">{age.label} Age · {age.genre}</p>
      <h1>{age.name}</h1>
      {age.subtitle && <p class="lede">{age.subtitle}</p>}
      <p class="lede">{age.description}</p>
      {age.quote && <blockquote>“{age.quote}”</blockquote>}

      <section aria-labelledby="snapshots-title">
        <h2 id="snapshots-title">Snapshot Cards</h2>
        <div class="placeholder-block">Age snapshots will open here.</div>
      </section>
      <section aria-labelledby="article-title">
        <h2 id="article-title">Article</h2>
        <div class="placeholder-block">The full Age article will follow.</div>
      </section>
    </div>
  </main>
</BaseLayout>

<style>
  .age-page blockquote { max-width: 48rem; margin: 3rem 0; padding-left: 1.5rem; color: color-mix(in srgb, var(--accent) 45%, white); border-left: 1px solid var(--accent); font-family: var(--serif); font-size: clamp(1.4rem, 3vw, 2.2rem); }
  .age-page section { margin-top: 6rem; }
</style>
