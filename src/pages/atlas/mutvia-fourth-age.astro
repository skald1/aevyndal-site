---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { contentfulClient } from "../../lib/contentful";

const slug = "mutvia-fourth-age";
const fallbackCountry = {
  name: "Mütvia",
  pronunciation: "MOOT-vee-ah",
  alsoKnownAs: "The Land of 1,000 Princes",
  age: "Fourth Age",
  region: "Northern Erinnal",
  government:
    "Decentralized principalities. Approximately 500 ruling ströikas at any given time, with hundreds more petty lords beneath them.",
  capital: "None. Each principality is autonomous.",
  languages: "Mütvian",
  primaryInhabitants: "Klane (human), Slindar'il, Fayd'il, T'nao, Igyrlin",
  borders:
    "West: Sta'abri. East: Slindar'il Nation. Northeast: Amsträd. South: Cultrek.",
  overview:
    "Little can be said about Mütvia without thoughts of creatures that go bump in the night. This is the stuff of legends: dark forests, black soils, restless dead, and spirits that move through the trees with complete indifference to whether you survive them.\n\nThe deeper truth is that Mütvia is defined by The Land itself. Nor'dagha, patron deity of Mütvia, is present in it. The Land is her manifest body, aware and active, enforcing a balance between the three castes that define Mütvian society: Nobles, Commoners, and Drósti.\n\nSuperstition here is not ignorance. It is survival. Gloom is the ambient state. Hope is the work.",
  history:
    "Mütvia's defining historical wound is the Liratein War of 659 IC, a conflict between Stroikas Aken Arduuskjil of the east and Stroika Drerai Endasoi of the west. The war reshaped the noble landscape permanently and left old claims, old resentments, and old dead in the soil.\n\nHouse Veshk, stripped of lands in the fallout, became the Veshtari: Mütvia's primary intelligence network, operating under the cover of a traveling theater company.",
  geography:
    "The Gergi River bisects Mütvia culturally as much as physically, dividing the rolling-consonant north from the tapped-consonant south. In the north, names are kept secret. In the south, you stand by your name.\n\nMount Verich dominates the south-central landscape. The Vorichnaya Woods occupy the northeast. Moldev holds the Veiled Gate, where the First Murder occurred and where all souls pass on their way to what comes next.",
  society:
    "NOBLES\nNobles provide structure and direction. Their edicts shape a domain, and some have access to hidden secrets of The Land.\n\nCOMMONERS\nCommoners are the body of Mütvia. They know the Land's threats most intimately because they live closest to them.\n\nDRÓSTI\nThe six Drósti families carry bloodlines older and stranger than ordinary heritage. They occupy a third space the caste system acknowledges but cannot fully contain.",
  culture:
    "SUPERSTITION AS PHYSICS\nThe operational practices Mütvians follow are not folklore. They are the accumulated findings of centuries living beside things that eat people.\n\nXENOPHOBIA AS RISK MANAGEMENT\nA stranger who does not know the superstitions is a liability. A stranger who does not know the undead catalog is a danger.\n\nTHE UNDEAD\nMütvia's undead are scavengers, not predators: unabsorbed corpses returning to finish what the soil started.",
  religion:
    "Nor'dagha is Mütvia's patron. The Land is her manifest presence, not a symbol of her. When sacred places are wounded, she may withdraw, and what fills the absence is rarely merciful.\n\nThe Veiled Gate in Moldev is not only a religious symbol. It is operational infrastructure. Burial rites in Mütvia are the mechanism by which a soul is properly processed.",
  notableFigures:
    "RA'ATH WOLVESBANE — The central human villain of Mütvia's present, a hunter whose every accusation is a confession he will never speak.\n\nDETRIUS AKENSKJIL — Son of the fallen Stroikas Aken Arduuskjil. Believed to be a master vampire somewhere in the northern forests.\n\nBORDÜ MÖMA — The Crone of the Woods, manifestation of Nor'dagha's active presence in the deep forest.",
  notableLocations:
    "MOLDEV — Northern highlands and home of the Veiled Gate.\n\nMOUNT VERICH — Active volcano in south-central Mütvia, seat of House Dracovich.\n\nTHE GERGI RIVER — The line along which Mütvia divides its understanding of identity.\n\nGOYEK STROYN — Eagle Rock, a wounded sacred site of Nor'dagha.",
};

let country = fallbackCountry;

if (contentfulClient) {
  try {
    const entries = await contentfulClient.getEntries({
      content_type: "country",
      "fields.slug": slug,
    });

    if (entries.items.length) {
      country = entries.items[0].fields as typeof fallbackCountry;
    }
  } catch (error) {
    console.warn(`Contentful lookup failed for ${slug}; using local fallback.`, error);
  }
}

function toHTML(text: string): string {
  if (!text) return "";
  return text
    .split(/\n\n+/)
    .map(p => `<p>${p.replace(/\n/g, "<br>")}</p>`)
    .join("");
}

function toSections(text: string): string {
  if (!text) return "";
  return text
    .split(/\n\n+/)
    .map(block => {
      const trimmed = block.trim();
      if (trimmed === trimmed.toUpperCase() && !trimmed.includes(".")) {
        return `<h3>${trimmed}</h3>`;
      }
      return `<p>${trimmed.replace(/\n/g, "<br>")}</p>`;
    })
    .join("");
}

function toFigures(text: string): string {
  if (!text) return "";
  return text
    .split(/\n\n+/)
    .map(block => {
      const lines = block.trim().split(/\n/);
      const first = lines[0];
      const rest = lines.slice(1).join("<br>");
      if (first === first.toUpperCase() && first.includes("—")) {
        const [name, ...desc] = first.split("—");
        return `<div class="figure-block">
          <h3>${name.trim()}</h3>
          <p>${desc.join("—").trim()}${rest ? "<br>" + rest : ""}</p>
        </div>`;
      }
      return `<div class="figure-block"><p>${block.replace(/\n/g, "<br>")}</p></div>`;
    })
    .join("");
}
---

<BaseLayout title={`${country.name} — Ævyndal Atlas`} description={country.overview || ""}>
  <main class="country-page">

    <nav class="breadcrumb">
      <a href="/atlas">Atlas</a> / <span>{country.name}</span>
    </nav>

    <header class="country-header">
      <div class="country-age">{country.age}</div>
      <h1>{country.name}</h1>
      {country.pronunciation && <p class="pronunciation">/{country.pronunciation}/</p>}
      {country.alsoKnownAs && <p class="aka">Also known as: {country.alsoKnownAs}</p>}
    </header>

    <div class="country-meta">
      {country.capital && <div><span>Capital</span><p>{country.capital}</p></div>}
      {country.government && <div><span>Government</span><p>{country.government}</p></div>}
      {country.languages && <div><span>Languages</span><p>{country.languages}</p></div>}
      {country.primaryInhabitants && <div><span>Peoples</span><p>{country.primaryInhabitants}</p></div>}
      {country.region && <div><span>Region</span><p>{country.region}</p></div>}
      {country.borders && <div><span>Borders</span><p>{country.borders}</p></div>}
    </div>

<div class="country-body">
  {country.overview && (
    <section>
      <h2>Overview</h2>
      <Fragment set:html={toHTML(country.overview)} />
    </section>
  )}
  {country.history && (
    <section>
      <h2>History</h2>
      <Fragment set:html={toHTML(country.history)} />
    </section>
  )}
  {country.geography && (
    <section>
      <h2>Geography</h2>
      <Fragment set:html={toHTML(country.geography)} />
    </section>
  )}
  {country.society && (
    <section>
      <h2>Society</h2>
      <Fragment set:html={toSections(country.society)} />
    </section>
  )}
  {country.culture && (
    <section>
      <h2>Culture</h2>
      <Fragment set:html={toSections(country.culture)} />
    </section>
  )}
  {country.religion && (
    <section>
      <h2>Religion & Belief</h2>
      <Fragment set:html={toHTML(country.religion)} />
    </section>
  )}
  {country.notableFigures && (
    <section>
      <h2>Notable Figures</h2>
      <div class="figures">
        <Fragment set:html={toFigures(country.notableFigures)} />
      </div>
    </section>
  )}
  {country.notableLocations && (
    <section>
      <h2>Notable Locations</h2>
      <div class="figures">
        <Fragment set:html={toFigures(country.notableLocations)} />
      </div>
    </section>
  )}
</div>

  </main>
</BaseLayout>

<style>
  .country-page {
    max-width: 860px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }
  .breadcrumb {
    font-family: 'Lora', serif;
    font-size: 0.8rem;
    color: #5C5650;
    margin-bottom: 2rem;
  }
  .breadcrumb a {
    color: #8B3218;
    text-decoration: none;
  }
  .country-header {
    margin-bottom: 2rem;
  }
  .country-age {
    font-family: 'Lora', serif;
    font-size: 0.75rem;
    color: #8B3218;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
  }
  .country-header h1 {
    font-family: 'Crimson Text', serif;
    font-size: 4rem;
    color: #D0C9BC;
    margin-bottom: 0.5rem;
  }
  .pronunciation {
    font-family: 'Lora', serif;
    color: #5C5650;
    font-style: italic;
  }
  .aka {
    font-family: 'Lora', serif;
    color: #5C5650;
    font-size: 0.875rem;
  }
  .country-meta {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
    background: #1A1614;
    border: 1px solid #2a2420;
    padding: 1.5rem;
    margin-bottom: 3rem;
  }
  .country-meta span {
    font-family: 'Lora', serif;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #8B3218;
    display: block;
    margin-bottom: 0.25rem;
  }
  .country-meta p {
    font-family: 'Lora', serif;
    color: #D0C9BC;
    font-size: 0.875rem;
  }
  .country-body section {
    margin-bottom: 3rem;
  }
  .country-body h2 {
    font-family: 'Crimson Text', serif;
    font-size: 1.75rem;
    color: #D0C9BC;
    border-bottom: 1px solid #2a2420;
    padding-bottom: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .country-body p {
    font-family: 'Lora', serif;
    color: #8A8172;
    line-height: 1.8;
    font-size: 1rem;
    margin-bottom: 1rem;
  }
  .figures {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .figure-block {
    border-left: 2px solid #8B3218;
    padding-left: 1.5rem;
  }
  .figure-block h3 {
    font-family: 'Crimson Text', serif;
    font-size: 1.25rem;
    color: #D0C9BC;
    margin-bottom: 0.5rem;
  }
  .figure-block p {
    font-family: 'Lora', serif;
    color: #8A8172;
    line-height: 1.8;
    font-size: 0.95rem;
  }
  .country-body h3 {
  font-family: 'Crimson Text', serif;
  font-size: 1.1rem;
  color: #C4501E;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  margin-top: 2rem;
  margin-bottom: 0.75rem;
}
</style>
