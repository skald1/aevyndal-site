{
  "name": "aevyndal",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && pagefind --site dist",
    "cf:typegen": "wrangler types src/types/cloudflare-env.d.ts --env-interface CloudflareEnv --include-runtime=false --env-file cloudflare.env.example",
    "deploy": "npm run build && wrangler pages deploy dist --project-name aevyndal",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.3",
    "astro": "^6.4.2",
    "pagefind": "^1.5.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260619.1",
    "sass": "^1.101.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.103.0"
  }
}
